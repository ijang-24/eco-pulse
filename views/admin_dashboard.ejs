<section class="space-y-8">
    <!-- Admin Header Stats -->
    <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-[2.5rem] bg-gradient-to-br from-emerald-600 to-teal-500 p-8 text-white shadow-xl shadow-emerald-900/10">
            <p class="text-xs font-bold uppercase tracking-widest opacity-80">Total Warga</p>
            <h3 class="mt-2 text-4xl font-black"><%= stats.users %></h3>
            <p class="mt-1 text-sm font-medium opacity-70">Warga terdaftar aktif</p>
        </div>
        <div class="rounded-[2.5rem] bg-gradient-to-br from-amber-500 to-orange-400 p-8 text-white shadow-xl shadow-amber-900/10">
            <p class="text-xs font-bold uppercase tracking-widest opacity-80">Total Sampah</p>
            <h3 class="mt-2 text-4xl font-black"><%= stats.waste.toFixed(1) %> <span class="text-lg">kg</span></h3>
            <p class="mt-1 text-sm font-medium opacity-70">Berhasil didaur ulang</p>
        </div>
        <div class="rounded-[2.5rem] bg-gradient-to-br from-sky-600 to-indigo-500 p-8 text-white shadow-xl shadow-sky-900/10">
            <p class="text-xs font-bold uppercase tracking-widest opacity-80">Ekosistem Poin</p>
            <h3 class="mt-2 text-4xl font-black"><%= stats.points.toLocaleString() %></h3>
            <p class="mt-1 text-sm font-medium opacity-70">Poin dalam sirkulasi</p>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="flex flex-wrap gap-4">
        <a href="/admin/rewards" class="flex items-center gap-3 rounded-2xl bg-slate-900 px-6 py-4 font-bold text-white transition hover:bg-slate-800">
            <span>🎁 Kelola Reward</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
            </svg>
        </a>
    </div>

    <!-- Verification Queue -->
    <div class="rounded-[2.5rem] border border-slate-100 bg-white p-8 shadow-sm">
        <div class="mb-8 flex items-center justify-between">
            <h2 class="text-2xl font-black text-slate-950">Queue Validasi</h2>
            <span class="rounded-full bg-amber-100 px-4 py-1.5 text-xs font-bold text-amber-700">Pending: <%= logs.filter(l => l.status === "pending").length %></span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-50 text-[10px] font-bold uppercase tracking-widest text-slate-400">
                        <th class="px-6 py-4">Warga</th>
                        <th class="px-6 py-4">Detail Sampah</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% logs.forEach(log => { %>
                        <tr>
                            <td class="px-6 py-6">
                                <p class="font-bold text-slate-900"><%= log.username %></p>
                                <p class="text-xs text-slate-400">RT <%= log.rt %> / RW <%= log.rw %></p>
                            </td>
                            <td class="px-6 py-6">
                                <p class="text-sm font-bold capitalize"><%= log.waste_type %></p>
                                <p class="text-xs text-slate-500"><%= log.weight %> kg · <span class="text-emerald-600 font-bold">+<%= log.points_earned %> PTS</span></p>
                            </td>
                            <td class="px-6 py-6">
                                <span class="rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-widest 
                                    <%= log.status === \"verified\" ? \"bg-emerald-100 text-emerald-700\" : 
                                       log.status === \"rejected\" ? \"bg-rose-100 text-rose-700\" : \"bg-amber-100 text-amber-700\" %>">
                                    <%= log.status %>
                                </span>
                            </td>
                            <td class="px-6 py-6 text-right">
                                <form action=\"/admin/verify/<%= log.id %>\" method=\"POST\" class=\"inline-flex gap-2\">
                                    <button name=\"status\" value=\"verified\" class=\"h-10 w-10 rounded-xl bg-emerald-50 text-emerald-600 transition hover:bg-emerald-600 hover:text-white flex items-center justify-center\">
                                        <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"h-5 w-5\" viewBox=\"0 0 20 20\" fill=\"currentColor\"><path d=\"M0 0h24v24H0z\" fill=\"none\"/><path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\"/></svg>
                                    </button>
                                    <button name=\"status\" value=\"rejected\" class=\"h-10 w-10 rounded-xl bg-rose-50 text-rose-600 transition hover:bg-rose-600 hover:text-white flex items-center justify-center\">
                                        <svg xmlns=\"http://www.w3.org/2000/svg\" class=\"h-5 w-5\" viewBox=\"0 0 20 20\" fill=\"currentColor\"><path d=\"M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z\"/></svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</section>
