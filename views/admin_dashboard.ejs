<section class="space-y-8">
    <!-- Admin Header -->
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-amber-600 via-orange-500 to-rose-400 p-8 text-white shadow-[0_20px_50px_rgba(245,158,11,0.15)] lg:p-12">
        <div class="absolute -right-10 top-10 h-40 w-40 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
            <div>
                <p class="inline-flex rounded-full bg-white/15 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-white ring-1 ring-white/30">System Administration</p>
                <h1 class="mt-4 text-4xl font-extrabold tracking-tight lg:text-5xl">Community <span class="text-amber-200">Review Panel</span></h1>
                <p class="mt-2 text-amber-50/90 font-medium">Validasi kontribusi warga untuk menjaga integritas data lingkungan komunitas.</p>
            </div>
            <div class="flex items-center gap-4 rounded-2xl bg-white/10 p-4 backdrop-blur-md ring-1 ring-white/20">
                <div class="text-right">
                    <p class="text-xs font-bold uppercase tracking-widest text-amber-100">Pending Review</p>
                    <p class="text-2xl font-black"><%= logs.filter(l => l.status === 'pending').length %></p>
                </div>
                <div class="h-10 w-px bg-white/20"></div>
                <div class="text-right">
                    <p class="text-xs font-bold uppercase tracking-widest text-amber-100">Total Logs</p>
                    <p class="text-2xl font-black"><%= logs.length %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Table -->
    <div class="rounded-[2.5rem] border border-amber-100 bg-white/95 p-6 shadow-[0_20px_60px_rgba(245,158,11,0.08)] backdrop-blur-xl lg:p-8">
        <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <h2 class="text-2xl font-extrabold text-slate-900">Queue Validasi Sampah</h2>
            <div class="flex items-center gap-2">
                <span class="flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                <p class="text-sm font-bold text-slate-500 uppercase tracking-widest">Real-time Review System</p>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-100 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">
                        <th class="px-6 py-4">Citizen & Location</th>
                        <th class="px-6 py-4">Waste Details</th>
                        <th class="px-6 py-4">Proof of Action</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Verification Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% if (logs && logs.length > 0) { %>
                        <% logs.forEach(log => { %>
                            <tr class="group transition hover:bg-slate-50/50">
                                <td class="px-6 py-6">
                                    <div class="flex items-center gap-4">
                                        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-50 text-sm font-black text-amber-600">
                                            <%= log.username.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <p class="text-base font-extrabold text-slate-900"><%= log.username %></p>
                                            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">RT <%= log.rt %> / RW <%= log.rw %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <p class="text-sm font-extrabold capitalize text-slate-900"><%= log.waste_type %></p>
                                    <div class="mt-1 flex items-center gap-2">
                                        <span class="text-sm font-bold text-slate-600"><%= log.weight %> kg</span>
                                        <span class="h-1 w-1 rounded-full bg-slate-300"></span>
                                        <span class="text-[10px] font-black text-emerald-600">+<%= log.points_earned %> PTS</span>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <% if (log.photo_url) { %>
                                        <button onclick="Swal.fire({imageUrl: '<%= log.photo_url %>', imageAlt: 'Proof', showConfirmButton: false, customClass: {popup: 'rounded-[2rem]'}})" class="relative h-14 w-20 overflow-hidden rounded-xl bg-slate-100 ring-2 ring-transparent transition group-hover:ring-amber-200">
                                            <img src="<%= log.photo_url %>" class="h-full w-full object-cover">
                                            <div class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 transition group-hover:opacity-100">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                                </svg>
                                            </div>
                                        </button>
                                    <% } else { %>
                                        <span class="text-xs font-bold italic text-slate-300">No Photo Attached</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-6 text-sm font-medium">
                                    <span class="inline-flex rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-widest 
                                        <%= log.status === 'verified' ? 'bg-emerald-100 text-emerald-700' : 
                                           log.status === 'rejected' ? 'bg-rose-100 text-rose-700' : 'bg-amber-100 text-amber-700' %>">
                                        <%= log.status %>
                                    </span>
                                </td>
                                <td class="px-6 py-6 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <form action="/admin/verify/<%= log.id %>" method="POST" class="inline-flex gap-2">
                                            <button name="status" value="verified" title="Verify contribution" class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 transition hover:bg-emerald-600 hover:text-white shadow-sm">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                </svg>
                                            </button>
                                            <button name="status" value="rejected" title="Reject contribution" class="flex h-10 w-10 items-center justify-center rounded-xl bg-rose-50 text-rose-600 transition hover:bg-rose-600 hover:text-white shadow-sm">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                                </svg>
                                            </button>
                                        </form>
                                        <div class="h-8 w-px bg-slate-100 mx-1"></div>
                                        <form action="/admin/delete/<%= log.id %>" method="POST" onsubmit="return confirm('Hapus permanen data ini?')">
                                            <button type="submit" title="Delete record" class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-400 transition hover:bg-slate-900 hover:text-white">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center">
                                    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-slate-50 text-slate-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                                        </svg>
                                    </div>
                                    <p class="mt-4 text-sm font-bold text-slate-400 uppercase tracking-widest">Antrian Kosong</p>
                                    <p class="mt-1 text-xs text-slate-400">Belum ada kontribusi warga yang perlu direview saat ini.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</section>
