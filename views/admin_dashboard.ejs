<div class="animate-in fade-in slide-in-from-bottom-4 duration-1000">
    <!-- Fresh & Vibrant Header -->
    <div class="relative mb-10 overflow-hidden rounded-[3rem] bg-gradient-to-br from-emerald-500 via-emerald-400 to-lime-300 p-8 text-white shadow-[0_20px_50px_rgba(16,185,129,0.2)] lg:p-12">
        <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/20 blur-3xl"></div>
        <div class="absolute -left-10 -bottom-10 h-40 w-40 rounded-full bg-lime-200/30 blur-2xl"></div>
        
        <div class="relative flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-3">
                <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/20 backdrop-blur-md ring-1 ring-white/50">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <h1 class="text-4xl font-black tracking-tight">Eco-Admin Panel</h1>
                </div>
                <p class="text-emerald-50 font-bold max-w-lg leading-relaxed">Kelola kontribusi lingkungan komunitas dengan antarmuka yang segar dan cerdas.</p>
            </div>
            
            <div class="flex flex-wrap gap-3 mt-4 lg:mt-0 lg:justify-end">
                <form action="/admin/verify-bulk-ai" method="POST">
                    <button type="submit" class="group flex items-center gap-2 rounded-2xl bg-white px-5 py-3 text-xs md:text-sm font-black text-emerald-600 shadow-xl transition hover:scale-[1.05] active:scale-95">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        AI Auto-Verify
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Search Bar -->
    <div class="mb-10 relative max-w-2xl mx-auto">
        <input type="text" id="adminSearch" placeholder="Cari nama warga, RT, atau RW..." 
               class="w-full rounded-[2rem] bg-white border-2 border-emerald-50 px-10 py-5 text-lg font-bold text-slate-800 placeholder-slate-300 shadow-xl focus:border-emerald-400 focus:outline-none focus:ring-4 focus:ring-emerald-500/10 transition-all duration-300">
        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </div>
    </div>

    <!-- Stats Dashboard -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
        <div class="group relative rounded-[2.5rem] border-2 border-blue-50 bg-white p-8 shadow-[0_15px_40px_rgba(59,130,246,0.05)] transition hover:border-blue-200">
            <div class="flex items-center justify-between mb-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-50 text-blue-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-blue-400">Total Warga</span>
            </div>
            <p class="text-5xl font-black text-slate-800"><%= stats.users %></p>
        </div>

        <div class="group relative rounded-[2.5rem] border-2 border-emerald-50 bg-white p-8 shadow-[0_15px_40px_rgba(16,185,129,0.05)] transition hover:border-emerald-200">
            <div class="flex items-center justify-between mb-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                    </svg>
                </div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-emerald-400">Sampah Terverifikasi</span>
            </div>
            <p class="text-5xl font-black text-emerald-600"><%= Number(stats.waste).toFixed(1) %><span class="text-xl ml-1">kg</span></p>
        </div>

        <div class="group relative rounded-[2.5rem] border-2 border-amber-50 bg-white p-8 shadow-[0_15px_40px_rgba(245,158,11,0.05)] transition hover:border-amber-200">
            <div class="flex items-center justify-between mb-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-50 text-amber-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-amber-400">Total Poin</span>
            </div>
            <p class="text-5xl font-black text-amber-500"><%= stats.points %></p>
        </div>
    </div>

    <!-- Main Section -->
    <div class="grid gap-10 lg:grid-cols-3">
        <!-- Activity List -->
        <div class="lg:col-span-2 space-y-6">
            <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
                <h2 class="text-2xl font-black text-slate-800 tracking-tight flex items-center gap-3">
                    <span class="h-8 w-1.5 rounded-full bg-emerald-500"></span>
                    Aktivitas Terbaru
                </h2>
                
                <!-- Tab Navigation -->
                <div class="flex p-1.5 bg-slate-100 rounded-2xl w-fit">
                    <button onclick="switchTab('pending')" id="tabPending" class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 bg-white text-emerald-600 shadow-sm">
                        Pending
                        <span class="ml-2 px-2 py-0.5 rounded-lg bg-emerald-100 text-emerald-600 text-[10px]">
                            <%= logs.filter(l => l.status === 'pending').length %>
                        </span>
                    </button>
                    <button onclick="switchTab('verified')" id="tabVerified" class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 text-slate-400 hover:text-slate-600">
                        Verified
                        <span class="ml-2 px-2 py-0.5 rounded-lg bg-slate-200 text-slate-500 text-[10px]">
                            <%= logs.filter(l => l.status === 'verified').length %>
                        </span>
                    </button>
                </div>
            </div>
            
            <div id="logsContainer" class="space-y-4">
                <% if (logs && logs.length > 0) { %>
                    <% logs.forEach((log, index) => { %>
                        <div class="log-card group overflow-hidden rounded-[2.5rem] bg-white p-6 shadow-[0_10px_30px_rgba(0,0,0,0.03)] ring-1 ring-slate-100 transition hover:ring-emerald-200 hover:shadow-xl lg:p-8 <%= log.status !== 'pending' ? 'hidden' : '' %>"
                             data-status="<%= log.status %>"
                             data-username="<%= log.username.toLowerCase() %>" 
                             data-rt="<%= log.rt %>" 
                             data-rw="<%= log.rw %>">
                            <div class="flex flex-col gap-6 lg:flex-row lg:items-center">
                                <% if (log.photo_url) { %>
                                    <div class="h-24 w-24 shrink-0 overflow-hidden rounded-3xl border-4 border-slate-50 shadow-inner cursor-pointer" 
                                         onclick="openImageModal('<%= log.photo_url %>')">
                                        <img src="<%= log.photo_url %>" alt="Waste" class="h-full w-full object-cover transition duration-500 group-hover:scale-110">
                                    </div>
                                <% } %>
                                
                                <div class="flex-1 space-y-2">
                                    <div class="flex flex-wrap items-center gap-3">
                                        <h3 class="text-xl font-black text-slate-800"><%= log.username %></h3>
                                        <% if (log.user && log.user.is_trusted) { %>
                                            <span class="inline-flex items-center gap-1 rounded-full bg-blue-50 px-3 py-1 text-[10px] font-black uppercase text-blue-600 ring-1 ring-blue-100">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                                </svg>
                                                Trusted
                                            </span>
                                        <% } %>
                                        <span class="rounded-full bg-slate-100 px-3 py-1 text-[10px] font-black uppercase text-slate-500">RT <%= log.rt %> / RW <%= log.rw %></span>
                                        <span class="rounded-full px-4 py-1 text-[10px] font-black uppercase tracking-widest shadow-sm
                                            <%= log.status === 'verified' ? 'bg-emerald-100 text-emerald-600' : 
                                               log.status === 'rejected' ? 'bg-rose-100 text-rose-600' : 'bg-amber-100 text-amber-600' %>">
                                            <%= log.status %>
                                        </span>
                                    </div>
                                    
                                    <div class="flex flex-wrap gap-2">
                                        <% if (log.items && log.items.length > 0) { %>
                                            <% log.items.forEach(item => { %>
                                                <span class="rounded-lg bg-emerald-50/50 px-2 py-1 text-xs font-bold text-emerald-700 ring-1 ring-emerald-100/50">
                                                    🌿 <%= item.waste_type %>
                                                </span>
                                            <% }) %>
                                        <% } %>
                                    </div>
                                    
                                    <p class="text-sm font-bold text-slate-500">
                                        <span class="text-slate-800"><%= log.weight %> kg</span> · <span class="text-emerald-500">+<%= log.total_points ?? log.points_earned ?? 0 %> PTS</span>
                                    </p>
                                </div>

                                <div class="flex items-center gap-3">
                                    <% if (log.status === 'pending') { %>
                                        <form action="/admin/verify/<%= log.id %>" method="POST">
                                            <input type="hidden" name="status" value="verified">
                                            <button type="submit" class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-500 text-white shadow-lg shadow-emerald-100 transition hover:bg-emerald-600 hover:scale-105 active:scale-90">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                                </svg>
                                            </button>
                                        </form>
                                        <form action="/admin/verify/<%= log.id %>" method="POST">
                                            <input type="hidden" name="status" value="rejected">
                                            <button type="submit" class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white border-2 border-rose-100 text-rose-500 transition hover:bg-rose-50 active:scale-90">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
                                                </svg>
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <form action="/admin/delete/<%= log.id %>" method="POST" onsubmit="return confirm('Hapus permanent?')">
                                            <button type="submit" class="text-slate-300 hover:text-rose-500 transition">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="mt-8 flex justify-center gap-4">
                <% if (logs && logs.length > 5) { %>
                    <button id="seeMoreBtn" class="inline-flex items-center gap-2 rounded-2xl bg-white px-8 py-4 font-black text-emerald-600 shadow-xl ring-1 ring-emerald-100 transition hover:bg-emerald-50 active:scale-95">
                        Lihat Lebih Banyak 
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>
                    <button id="seeLessBtn" class="hidden inline-flex items-center gap-2 rounded-2xl bg-white px-8 py-4 font-black text-rose-500 shadow-xl ring-1 ring-rose-100 transition hover:bg-rose-50 active:scale-95">
                        Lihat Lebih Sedikit
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7" />
                        </svg>
                    </button>
                <% } %>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
            <div class="rounded-[2.5rem] bg-white p-8 shadow-[0_15px_40px_rgba(0,0,0,0.03)] ring-1 ring-slate-100">
                <h3 class="text-xl font-black text-slate-800 mb-6">🏆 RT Performance</h3>
                <div class="space-y-6">
                    <% rtPerformance.forEach((rt, idx) => { %>
                        <div class="space-y-2">
                            <div class="flex justify-between text-[11px] font-black uppercase tracking-widest text-slate-400">
                                <span><%= rt.label %></span>
                                <span class="text-emerald-500"><%= Number(rt.weight).toFixed(1) %> kg</span>
                            </div>
                            <div class="h-3 w-full rounded-full bg-slate-50 overflow-hidden ring-1 ring-slate-100">
                                <div class="h-full bg-gradient-to-r from-emerald-400 to-lime-300 transition-all duration-1000" style="width: <%= Math.min(100, (rt.weight/500)*100) %>%"></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="rounded-[2.5rem] bg-white p-8 shadow-[0_15px_40px_rgba(0,0,0,0.03)] ring-1 ring-slate-100">
                <h3 class="text-xl font-black text-slate-800 mb-2">📊 Community Waste</h3>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-8">Semua Setoran (Pending & Verified)</p>
                <div class="relative h-64">
                    <canvas id="adminBreakdownChart"></canvas>
                </div>
                <div class="mt-8 flex flex-wrap gap-2">
                    <% breakdownData.labels.forEach((label, i) => { %>
                        <div class="flex items-center gap-2 rounded-xl bg-slate-50 px-3 py-1.5 border border-slate-100">
                            <span class="h-2 w-2 rounded-full" style="background-color: <%= ['#00D1FF', '#FFB800', '#FF4D4D', '#A155FF', '#10B981'][i % 5] %>"></span>
                            <span class="text-[10px] font-black uppercase text-slate-600"><%= label %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="imageModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-white/95 backdrop-blur-md p-4" onclick="closeImageModal()">
    <img id="modalImage" src="" class="max-w-4xl w-full rounded-[2.5rem] shadow-2xl ring-1 ring-slate-100">
</div>

<script>
    // Tab Switching Feature
    let currentTab = 'pending';

    function switchTab(tab) {
        currentTab = tab;
        const pendingBtn = document.getElementById('tabPending');
        const verifiedBtn = document.getElementById('tabVerified');
        
        if (tab === 'pending') {
            pendingBtn.className = "px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 bg-white text-emerald-600 shadow-sm";
            verifiedBtn.className = "px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 text-slate-400 hover:text-slate-600";
        } else {
            verifiedBtn.className = "px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 bg-white text-emerald-600 shadow-sm";
            pendingBtn.className = "px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-300 text-slate-400 hover:text-slate-600";
        }

        // Show/Hide cards based on tab
        let visibleCount = 0;
        logCards.forEach(card => {
            const status = card.getAttribute('data-status');
            if (status === tab) {
                if (visibleCount < 5) card.classList.remove('hidden');
                else card.classList.add('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });

        // Reset pagination buttons
        const seeMoreBtn = document.getElementById('seeMoreBtn');
        const seeLessBtn = document.getElementById('seeLessBtn');
        if (seeMoreBtn) seeMoreBtn.style.display = visibleCount > 5 ? 'inline-flex' : 'none';
        if (seeLessBtn) seeLessBtn.classList.add('hidden');
    }

    // Search Feature
    const searchInput = document.getElementById('adminSearch');
    const logCards = document.querySelectorAll('.log-card');
    
    searchInput.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        let matchCount = 0;

        logCards.forEach(card => {
            const username = card.getAttribute('data-username');
            const rt = card.getAttribute('data-rt');
            const rw = card.getAttribute('data-rw');
            const status = card.getAttribute('data-status');
            
            if (status === currentTab && (username.includes(term) || rt.includes(term) || rw.includes(term))) {
                card.style.display = 'block';
                matchCount++;
            } else {
                card.style.display = 'none';
            }
        });
        
        // Hide pagination buttons when searching
        const seeMoreBtn = document.getElementById('seeMoreBtn');
        const seeLessBtn = document.getElementById('seeLessBtn');
        if (seeMoreBtn) seeMoreBtn.style.display = (term.length > 0 || matchCount <= 5) ? 'none' : 'inline-flex';
        if (seeLessBtn) seeLessBtn.style.display = 'none';
    });

    // See More / See Less Feature
    const seeMoreBtn = document.getElementById('seeMoreBtn');
    const seeLessBtn = document.getElementById('seeLessBtn');
    
    if (seeMoreBtn && seeLessBtn) {
        seeMoreBtn.addEventListener('click', () => {
            let count = 0;
            document.querySelectorAll(`.log-card.hidden[data-status="${currentTab}"]`).forEach((card, index) => {
                if (index < 5) card.classList.remove('hidden');
                count++;
            });
            
            seeLessBtn.classList.remove('hidden');
            if (document.querySelectorAll(`.log-card.hidden[data-status="${currentTab}"]`).length === 0) {
                seeMoreBtn.style.display = 'none';
            }
        });

        seeLessBtn.addEventListener('click', () => {
            let count = 0;
            logCards.forEach((card) => {
                if (card.getAttribute('data-status') === currentTab) {
                    if (count >= 5) card.classList.add('hidden');
                    count++;
                }
            });
            seeMoreBtn.style.display = 'inline-flex';
            seeLessBtn.classList.add('hidden');
            window.scrollTo({ top: searchInput.offsetTop - 100, behavior: 'smooth' });
        });
    }

    function openImageModal(url) {
        document.getElementById('modalImage').src = url;
        document.getElementById('imageModal').classList.remove('hidden');
        document.getElementById('imageModal').classList.add('flex');
    }
    function closeImageModal() {
        document.getElementById('imageModal').classList.add('hidden');
        document.getElementById('imageModal').classList.remove('flex');
    }
    document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('adminBreakdownChart').getContext('2d');
        const bData = <%- JSON.stringify(breakdownData) %>;
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: bData.labels,
                datasets: [{
                    data: bData.values,
                    backgroundColor: ['#00D1FF', '#FFB800', '#FF4D4D', '#A155FF', '#10B981'],
                    borderWidth: 5,
                    borderColor: '#ffffff',
                    hoverOffset: 15
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: { legend: { display: false } }
            }
        });
    });
</script>
