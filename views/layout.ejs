<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(74, 222, 128, 0.18), transparent 28%),
                radial-gradient(circle at top right, rgba(56, 189, 248, 0.14), transparent 24%),
                radial-gradient(circle at bottom right, rgba(251, 191, 36, 0.12), transparent 20%),
                linear-gradient(180deg, #fbfffd 0%, #f3fbf6 46%, #eef8ff 100%);
        }
    </style>
</head>
<body class="text-slate-900">
    
    <!-- Notification Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const successMsg = '<%= typeof success_msg !== "undefined" ? success_msg : "" %>';
            const errorMsg = '<%= typeof error_msg !== "undefined" ? error_msg : "" %>';

            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: successMsg,
                    timer: 3000,
                    showConfirmButton: false
                });
            }

            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: errorMsg
                });
            }

            // Notification Toggle
            const notifBell = document.getElementById('notifBell');
            const notifDropdown = document.getElementById('notifDropdown');

            if (notifBell) {
                notifBell.addEventListener('click', (e) => {
                    e.stopPropagation();
                    notifDropdown.classList.toggle('hidden');
                });

                document.addEventListener('click', (e) => {
                    if (notifDropdown && !notifDropdown.contains(e.target) && !notifBell.contains(e.target)) {
                        notifDropdown.classList.add('hidden');
                    }
                });
            }
        });

        async function markAllRead() {
            try {
                const response = await fetch('/notifications/read-all', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (response.ok) {
                    window.location.reload();
                }
            } catch (err) {
                console.error('Failed to mark notifications as read', err);
            }
        }
    </script>
    
    <!-- Navigation -->
    <nav class="sticky top-0 z-40 border-b <%= isAdminArea ? 'border-amber-100/80 bg-[rgba(255,251,235,0.9)] shadow-[0_10px_30px_rgba(251,191,36,0.10)]' : 'border-emerald-100/80 bg-white/82 shadow-[0_10px_30px_rgba(34,197,94,0.08)]' %> backdrop-blur-xl">
        <div class="container mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-4">
                    <span class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-full <%= isAdminArea ? 'bg-gradient-to-br from-amber-200 via-orange-100 to-rose-100 shadow-[0_12px_26px_rgba(251,191,36,0.18)]' : 'bg-gradient-to-br from-emerald-200 via-lime-100 to-sky-100 shadow-[0_12px_26px_rgba(34,197,94,0.18)]' %> ring-1 ring-white/80">
                        <span class="absolute h-6 w-6 -rotate-12 rounded-tl-[100%] rounded-tr-[20%] rounded-bl-[20%] rounded-br-[100%] <%= isAdminArea ? 'bg-amber-700' : 'bg-emerald-600' %>"></span>
                        <span class="absolute right-[11px] top-[12px] h-4 w-1 rounded-full bg-white/90 rotate-[28deg]"></span>
                        <span class="absolute bottom-[10px] h-1.5 w-6 rounded-full <%= isAdminArea ? 'bg-orange-300/90' : 'bg-lime-300/90' %>"></span>
                    </span>
                    <span class="hidden sm:block">
                        <span class="block text-[11px] font-bold uppercase tracking-[0.28em] <%= isAdminArea ? 'text-amber-700' : 'text-emerald-600' %>"><%= isAdminArea ? 'Admin Review System' : 'Community Impact System' %></span>
                        <span class="block text-2xl font-extrabold tracking-tight text-slate-950">Eco-Pulse</span>
                    </span>
                </a>

                <!-- Hamburger Button -->
                <button id="mobileMenuButton" class="rounded-xl p-2 transition hover:bg-slate-100 xl:hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                    </svg>
                </button>

                <!-- Desktop Menu -->
                <div class="hidden xl:flex xl:items-center xl:gap-4">
                    <div class="flex items-center gap-2 rounded-full <%= isAdminArea ? 'border-amber-100 bg-white/95 shadow-[0_8px_24px_rgba(251,191,36,0.08)]' : 'border-emerald-100 bg-white/90 shadow-[0_8px_24px_rgba(34,197,94,0.06)]' %> p-2 text-sm font-semibold text-slate-600">
                        <% if (!user || user.role !== 'admin') { %>
                            <a href="/dashboard" class="rounded-full px-4 py-2 transition <%= isAdminArea ? 'hover:bg-amber-50 hover:text-amber-800' : 'hover:bg-emerald-50 hover:text-emerald-800' %>">Dashboard</a>
                        <% } %>
                        <a href="/leaderboard" class="rounded-full px-4 py-2 transition hover:bg-sky-50 hover:text-sky-800">Leaderboard</a>
                        <a href="/rewards" class="rounded-full px-4 py-2 transition hover:bg-amber-50 hover:text-amber-800">Rewards</a>
                        <a href="/my-vouchers" class="rounded-full px-4 py-2 transition hover:bg-indigo-50 hover:text-indigo-800">My Vouchers</a>
                        <% if (user && user.role === 'admin') { %>
                            <a href="/admin/dashboard" class="rounded-full <%= isAdminArea ? 'bg-slate-900 text-white hover:bg-slate-800' : 'bg-amber-200 text-amber-950 hover:bg-amber-300' %> px-4 py-2 font-bold transition">Admin Panel</a>
                        <% } %>
                    </div>

                    <% if (user) { %>
                        <div class="flex flex-wrap items-center gap-3">
                            <!-- Notification Bell -->
                            <div class="relative">
                                <button id="notifBell" class="relative flex h-10 w-10 items-center justify-center rounded-full bg-white border border-emerald-100 text-slate-600 shadow-sm transition hover:bg-emerald-50 hover:text-emerald-700">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                                    </svg>
                                    <% if (unreadCount > 0) { %>
                                        <span class="absolute -right-1 -top-1 flex h-4 w-4 items-center justify-center rounded-full bg-rose-500 text-[9px] font-black text-white ring-2 ring-white">
                                            <%= unreadCount %>
                                        </span>
                                    <% } %>
                                </button>
                                
                                <!-- Notification Dropdown -->
                                <div id="notifDropdown" class="absolute right-0 mt-3 hidden w-80 overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-2xl animate-in slide-in-from-top-2 duration-200">
                                    <div class="flex items-center justify-between border-b border-slate-50 bg-slate-50/50 px-5 py-3">
                                        <h4 class="text-xs font-black uppercase tracking-widest text-slate-500">Notifications</h4>
                                        <% if (unreadCount > 0) { %>
                                            <button onclick="markAllRead()" class="text-[10px] font-bold text-emerald-600 hover:underline">Mark all read</button>
                                        <% } %>
                                    </div>
                                    <div class="max-h-80 overflow-y-auto">
                                        <% if (notifications && notifications.length > 0) { %>
                                            <% notifications.forEach(notif => { %>
                                                <div class="border-b border-slate-50 p-4 transition hover:bg-slate-50">
                                                    <div class="flex items-start gap-3">
                                                        <div class="mt-1 h-2 w-2 shrink-0 rounded-full <%= notif.type === 'verification' ? 'bg-emerald-500' : 'bg-indigo-500' %>"></div>
                                                        <div>
                                                            <p class="text-sm font-bold text-slate-900"><%= notif.title %></p>
                                                            <p class="mt-0.5 text-xs text-slate-500 leading-relaxed"><%= notif.message %></p>
                                                            <p class="mt-2 text-[9px] font-bold uppercase tracking-wider text-slate-400">
                                                                <%= new Date(notif.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        <% } else { %>
                                            <div class="p-8 text-center">
                                                <p class="text-sm font-medium text-slate-400">Tidak ada notifikasi baru.</p>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="bg-slate-50/50 px-5 py-3 text-center border-t border-slate-50">
                                        <a href="/waste/logs" class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 hover:text-slate-800 transition">View All Activity</a>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-full border border-emerald-100 bg-white px-4 py-2.5 text-sm text-slate-600 shadow-[0_8px_20px_rgba(34,197,94,0.06)]">
                                <span class="font-semibold text-slate-900"><%= user.username %></span>
                                <span class="mx-2 text-slate-300">/</span>
                                <span class="uppercase tracking-[0.12em] text-xs"><%= user.role %></span>
                            </div>
                            <a href="/logout" class="rounded-full bg-gradient-to-r from-emerald-600 to-lime-500 px-5 py-2.5 text-sm font-bold text-white transition hover:from-emerald-700 hover:to-lime-600">Logout</a>
                        </div>
                    <% } else { %>
                        <div class="flex items-center gap-3">
                            <a href="/login" class="rounded-full border border-emerald-100 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-800">Login</a>
                            <a href="/register" class="rounded-full bg-gradient-to-r from-emerald-600 to-lime-500 px-5 py-2.5 text-sm font-bold text-white transition hover:from-emerald-700 hover:to-lime-600">Register</a>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Mobile Menu -->
            <div id="mobileMenu" class="hidden mt-4 flex flex-col gap-4 xl:hidden">
                <div class="flex flex-col gap-2 rounded-2xl <%= isAdminArea ? 'border-amber-100 bg-white/95' : 'border-emerald-100 bg-white/90' %> p-4 text-sm font-semibold text-slate-600 border">
                    <% if (!user || user.role !== 'admin') { %>
                        <a href="/dashboard" class="rounded-xl px-4 py-3 transition hover:bg-emerald-50 hover:text-emerald-800">Dashboard</a>
                    <% } %>
                    <a href="/leaderboard" class="rounded-xl px-4 py-3 transition hover:bg-sky-50 hover:text-sky-800">Leaderboard</a>
                    <a href="/rewards" class="rounded-xl px-4 py-3 transition hover:bg-amber-50 hover:text-amber-800">Rewards</a>
                    <a href="/my-vouchers" class="rounded-xl px-4 py-3 transition hover:bg-indigo-50 hover:text-indigo-800">My Vouchers</a>
                    <% if (user && user.role === 'admin') { %>
                        <a href="/admin/dashboard" class="rounded-xl <%= isAdminArea ? 'bg-amber-100 text-amber-900' : 'bg-amber-200 text-amber-950' %> px-4 py-3 font-bold transition">Admin Panel</a>
                    <% } %>
                </div>

                <% if (user) { %>
                    <div class="flex flex-col gap-3 rounded-2xl border border-emerald-100 bg-white p-4 shadow-lg">
                        <div class="flex items-center justify-between px-2">
                            <span class="font-bold text-slate-900"><%= user.username %></span>
                            <span class="uppercase tracking-[0.12em] text-[10px] bg-slate-100 px-2 py-1 rounded-md text-slate-500"><%= user.role %></span>
                        </div>
                        <a href="/logout" class="text-center rounded-xl bg-gradient-to-r from-emerald-600 to-lime-500 py-3.5 text-sm font-extrabold text-white transition">Logout</a>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-2 gap-3">
                        <a href="/login" class="text-center rounded-xl border border-emerald-100 bg-white py-3.5 text-sm font-bold text-slate-700 transition">Login</a>
                        <a href="/register" class="text-center rounded-xl bg-gradient-to-r from-emerald-600 to-lime-500 py-3.5 text-sm font-extrabold text-white transition">Register</a>
                    </div>
                <% } %>
            </div>
        </div>
    </nav>

    <script>
        document.getElementById('mobileMenuButton').addEventListener('click', () => {
            document.getElementById('mobileMenu').classList.toggle('hidden');
        });
    </script>

    <% if (isAdminArea) { %>
        <div class="border-b border-amber-100 bg-gradient-to-r from-amber-100 via-orange-50 to-rose-50">
            <div class="container mx-auto flex flex-col gap-2 px-6 py-3 text-sm font-semibold text-amber-900 lg:flex-row lg:items-center lg:justify-between">
                <span class="uppercase tracking-[0.18em]">Admin Mode Active</span>
                <span>Anda sedang berada di area review dan validasi data komunitas.</span>
            </div>
        </div>
    <% } %>

    <!-- Main Content -->
    <main class="container mx-auto px-6 py-10 lg:py-12">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="mt-8 border-t border-emerald-100/80 bg-white/70 text-slate-500 backdrop-blur">
        <div class="container mx-auto px-6 text-center">
            <div class="py-8">
                <p class="text-sm font-semibold text-slate-700">&copy; 2026 Eco-Pulse Community</p>
                <p class="mt-2 text-sm text-slate-500">Built for cleaner neighborhoods and verifiable community action.</p>
            </div>
        </div>
    </footer>

</body>
</html>
