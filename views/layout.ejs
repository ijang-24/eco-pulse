                        <a href="/logout" class="block w-full py-4 rounded-2xl bg-rose-50 text-rose-600 font-black text-center hover:bg-rose-100 transition">Logout</a>
                    </div>
                </div>
            <% } else { %>
                <div class="mt-12 space-y-4">
                    <a href="/login" class="block w-full py-4 rounded-2xl bg-slate-100 text-slate-600 font-black text-center hover:bg-slate-200 transition-colors">Masuk</a>
                    <a href="/register" class="block w-full py-4 rounded-2xl bg-emerald-600 text-white font-black text-center shadow-xl shadow-emerald-200 hover:-translate-y-1 transition-transform">Mulai Sekarang →</a>
                </div>
