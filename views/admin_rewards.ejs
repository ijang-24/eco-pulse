<section class="space-y-8">
    <!-- Header Admin Reward -->
    <div class="rounded-[2.5rem] bg-gradient-to-br from-slate-900 to-slate-800 p-8 text-white shadow-xl">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black tracking-tight">Kelola Reward 🎁</h1>
                <p class="mt-2 text-slate-400 font-medium">Tambah atau hapus item reward untuk ditukarkan oleh warga.</p>
            </div>
            <button onclick="document.getElementById('addRewardModal').classList.remove('hidden')" class="flex items-center gap-2 rounded-2xl bg-emerald-600 px-6 py-4 font-bold text-white transition hover:bg-emerald-500 shadow-lg shadow-emerald-900/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Tambah Reward Baru
            </button>
        </div>
    </div>

    <!-- Rewards List Table -->
    <div class="rounded-[2.5rem] border border-slate-100 bg-white p-8 shadow-sm">
        <h2 class="text-2xl font-black text-slate-950 mb-8 text-center">Daftar Reward Aktif</h2>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-50 text-[10px] font-bold uppercase tracking-widest text-slate-400">
                        <th class="px-6 py-4">Item</th>
                        <th class="px-6 py-4">Harga Poin</th>
                        <th class="px-6 py-4">Stok</th>
                        <th class="px-6 py-4 text-right">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% if (rewards && rewards.length > 0) { %>
                        <% rewards.forEach(reward => { %>
                            <tr>
                                <td class="px-6 py-6">
                                    <div class="flex items-center gap-4">
                                        <div class="h-14 w-14 flex-shrink-0 overflow-hidden rounded-2xl bg-slate-50 border border-slate-100">
                                            <% if (reward.image_url) { %>
                                                <img src="<%= reward.image_url %>" class="h-full w-full object-cover">
                                            <% } else { %>
                                                <div class="flex h-full w-full items-center justify-center text-2xl">🎁</div>
                                            <% } %>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-900"><%= reward.title %></p>
                                            <p class="text-xs text-slate-400 line-clamp-1"><%= reward.description %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-6 font-bold text-amber-600">
                                    <%= reward.points_cost %> <span class="text-[10px] text-slate-400">PTS</span>
                                </td>
                                <td class="px-6 py-6 font-bold text-slate-900">
                                    <%= reward.stock %>
                                </td>
                                <td class="px-6 py-6 text-right">
                                    <!-- Delete Reward Form -->
                                    <form action="/admin/rewards/delete/<%= reward.id %>" method="POST" onsubmit="return confirm('Hapus reward ini?')">
                                        <button type="submit" class="h-10 w-10 rounded-xl bg-rose-50 text-rose-600 transition hover:bg-rose-600 hover:text-white flex items-center justify-center">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                                <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                            </svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="px-6 py-20 text-center text-slate-400 font-medium">Belum ada reward yang ditambahkan.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Modal Tambah Reward -->
<div id="addRewardModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-slate-950/80 backdrop-blur-sm p-4">
    <div class="relative max-w-lg w-full bg-white rounded-[2.5rem] p-8 shadow-2xl shadow-slate-950/20 transform">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-black text-slate-950">Tambah Reward</h2>
            <button onclick="document.getElementById('addRewardModal').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <form action="/admin/rewards/add" method="POST" class="space-y-6">
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Nama Reward</label>
                <input type="text" name="title" required placeholder="Contoh: Voucher Belanja" class="w-full rounded-2xl border-slate-100 bg-slate-50 p-4 font-bold text-slate-900 focus:border-emerald-500 focus:ring-emerald-500 transition shadow-sm">
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Deskripsi</label>
                <textarea name="description" placeholder="Jelaskan detail reward..." class="w-full rounded-2xl border-slate-100 bg-slate-50 p-4 font-bold text-slate-900 focus:border-emerald-500 focus:ring-emerald-500 transition shadow-sm" rows="3"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Harga Poin</label>
                    <input type="number" name="points_cost" required placeholder="0" class="w-full rounded-2xl border-slate-100 bg-slate-50 p-4 font-bold text-slate-900 focus:border-emerald-500 focus:ring-emerald-500 transition shadow-sm">
                </div>
                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Stok</label>
                    <input type="number" name="stock" required placeholder="0" class="w-full rounded-2xl border-slate-100 bg-slate-50 p-4 font-bold text-slate-900 focus:border-emerald-500 focus:ring-emerald-500 transition shadow-sm">
                </div>
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">URL Gambar (Opsional)</label>
                <input type="text" name="image_url" placeholder="https://..." class="w-full rounded-2xl border-slate-100 bg-slate-50 p-4 font-bold text-slate-900 focus:border-emerald-500 focus:ring-emerald-500 transition shadow-sm">
            </div>
            <button type="submit" class="w-full rounded-2xl bg-slate-900 p-4 font-black text-white transition hover:bg-emerald-600 shadow-xl shadow-slate-200">
                Simpan Reward
            </button>
        </form>
    </div>
</div>
