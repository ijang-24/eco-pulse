<div class="max-w-md mx-auto bg-white p-10 rounded-3xl shadow-lg border border-gray-100">
    <h1 class="text-3xl font-bold mb-6 text-center text-green-700">Join the Community</h1>
    <form action="/register" method="POST" class="space-y-4">
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Username</label>
            <input type="text" name="username" class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none" placeholder="ecowarrior" required>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Email Address</label>
            <input type="email" name="email" class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none" placeholder="you@example.com" required>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">RT / RW (Address)</label>
            <input type="text" name="address_rt" class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none" placeholder="RT 05 / RW 02" required>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Password</label>
            <input type="password" name="password" class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none" placeholder="••••••••" required>
        </div>
        <button type="submit" class="w-full bg-green-600 text-white py-4 mt-4 rounded-xl font-bold text-lg hover:bg-green-700 transition shadow-lg shadow-green-100">Create Account</button>
    </form>
    <p class="mt-6 text-center text-gray-500">
        Already have an account? <a href="/login" class="text-green-600 font-bold hover:underline">Login here</a>
    </p>
</div>
