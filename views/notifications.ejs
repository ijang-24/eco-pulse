<div class="animate-in fade-in slide-in-from-bottom-4 duration-700">
    <div class="mb-10">
        <h1 class="text-3xl font-black text-slate-900 tracking-tight">Notification History</h1>
        <p class="text-slate-500 font-medium">Semua aktivitas dan pembaruan akun Anda.</p>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden">
        <% if (notifications && notifications.length > 0) { %>
            <div class="divide-y divide-slate-50">
                <% notifications.forEach(notif => { %>
                    <div class="p-8 hover:bg-slate-50 transition-all <%= notif.is_read ? 'opacity-60' : '' %>">
                        <div class="flex gap-6 items-start">
                            <div class="h-14 w-14 shrink-0 rounded-2xl <%= notif.is_read ? 'bg-slate-100 text-slate-400' : 'bg-emerald-50 text-emerald-600' %> flex items-center justify-center text-2xl shadow-sm">
                                <% if (notif.type === 'reward_redemption') { %> 🎁 <% } else if (notif.type === 'waste_verified') { %> ✅ <% } else { %> 🔔 <% } %>
                            </div>
                            <div class="flex-1 space-y-2">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-lg font-black text-slate-900"><%= notif.title %></h3>
                                    <span class="text-xs font-bold text-slate-400 uppercase tracking-tighter">
                                        <%= new Date(notif.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %> · 
                                        <%= new Date(notif.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
                                    </span>
                                </div>
                                <p class="text-slate-600 font-medium leading-relaxed"><%= notif.message %></p>
                                <% if (!notif.is_read) { %>
                                    <span class="inline-block px-3 py-1 rounded-full bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest">New</span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="py-32 text-center">
                <div class="h-20 w-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4a2 2 0 012-2m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                    </svg>
                </div>
                <p class="text-slate-400 font-bold uppercase tracking-widest">Belum ada notifikasi untuk Anda.</p>
                <a href="/dashboard" class="mt-6 inline-block text-emerald-600 font-black text-sm hover:underline">Kembali ke Dashboard</a>
            </div>
        <% } %>
    </div>
</div>
