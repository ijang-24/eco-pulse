<section class="space-y-8 h-[calc(100vh-8rem)] flex flex-col">
    <div>
        <h1 class="text-3xl font-black text-slate-950">Logistik Jemput Sampah</h1>
        <p class="text-sm text-slate-500 font-medium">Manajemen armada penjemputan sampah warga menggunakan sistem Kanban.</p>
    </div>

    <!-- Kanban Board -->
    <div class="flex-1 grid grid-cols-1 lg:grid-cols-3 gap-6 overflow-hidden">
        
        <!-- Column: Pending -->
        <div class="bg-slate-50 rounded-[2rem] p-4 flex flex-col max-h-full border border-slate-100">
            <div class="flex items-center justify-between mb-4 px-2">
                <h3 class="font-black text-slate-700 flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-amber-400"></div> Menunggu
                </h3>
                <span class="text-xs font-bold bg-white px-2 py-1 rounded-lg text-slate-400 shadow-sm"><%= pending.length %></span>
            </div>
            <div class="flex-1 overflow-y-auto space-y-3 px-2 pb-4 kanban-col" id="col-pending">
                <% pending.forEach(p => { %>
                    <%- include('partials/pickup_card', { p }) %>
                <% }) %>
                <% if(pending.length === 0) { %>
                    <div class="text-center p-8 text-xs font-bold text-slate-400 border-2 border-dashed border-slate-200 rounded-2xl">Tidak ada antrean</div>
                <% } %>
            </div>
        </div>

        <!-- Column: On The Way -->
        <div class="bg-indigo-50/50 rounded-[2rem] p-4 flex flex-col max-h-full border border-indigo-50">
            <div class="flex items-center justify-between mb-4 px-2">
                <h3 class="font-black text-indigo-900 flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-indigo-500 animate-pulse"></div> Menuju Lokasi
                </h3>
                <span class="text-xs font-bold bg-white px-2 py-1 rounded-lg text-indigo-400 shadow-sm"><%= onTheWay.length %></span>
            </div>
            <div class="flex-1 overflow-y-auto space-y-3 px-2 pb-4 kanban-col" id="col-otw">
                <% onTheWay.forEach(p => { %>
                    <%- include('partials/pickup_card', { p }) %>
                <% }) %>
                <% if(onTheWay.length === 0) { %>
                    <div class="text-center p-8 text-xs font-bold text-indigo-300 border-2 border-dashed border-indigo-100 rounded-2xl">Tidak ada armada jalan</div>
                <% } %>
            </div>
        </div>

        <!-- Column: Completed -->
        <div class="bg-emerald-50/50 rounded-[2rem] p-4 flex flex-col max-h-full border border-emerald-50">
            <div class="flex items-center justify-between mb-4 px-2">
                <h3 class="font-black text-emerald-800 flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-emerald-500"></div> Selesai
                </h3>
                <span class="text-xs font-bold bg-white px-2 py-1 rounded-lg text-emerald-400 shadow-sm"><%= completed.length %></span>
            </div>
            <div class="flex-1 overflow-y-auto space-y-3 px-2 pb-4 kanban-col" id="col-completed">
                <% completed.forEach(p => { %>
                    <%- include('partials/pickup_card', { p }) %>
                <% }) %>
            </div>
        </div>

    </div>
</section>
