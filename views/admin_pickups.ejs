<style>
    .tbl-row:hover { background: #f8fafc; }
    .slim-scroll::-webkit-scrollbar { width: 3px; }
    .slim-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 99px; }
</style>

<%
    // Active tab logic
    const activeTab = (typeof tabFilter !== 'undefined' ? tabFilter : 'pending');
    const tabs = [
        { key: 'pending',    label: 'Menunggu',      count: totalPending,    dot: '#f59e0b' },
        { key: 'on_the_way', label: 'Menuju Lokasi', count: totalOnTheWay,   dot: '#3b82f6' },
        { key: 'completed',  label: 'Selesai',        count: totalCompleted,  dot: '#10b981' },
    ];
    const rows = activeTab === 'pending' ? pending : activeTab === 'on_the_way' ? onTheWay : completed;
%>

<section class="h-[calc(100vh-7rem)] flex flex-col space-y-4">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 flex-shrink-0">
        <div>
            <h1 class="text-2xl font-black text-slate-900">Logistik Penjemputan</h1>
            <p class="text-xs text-slate-400 font-medium mt-0.5">
                <%= totalPending + totalOnTheWay %> aktif &nbsp;·&nbsp; <%= totalCompleted %> selesai
            </p>
        </div>

        <!-- Search -->
        <form action="/admin/pickups" method="GET" class="flex gap-2 flex-shrink-0">
            <input type="hidden" name="tab" value="<%= activeTab %>">
            <div class="relative">
                <input type="text" name="search" value="<%= search %>"
                    placeholder="Cari nama / alamat / ID..."
                    class="w-56 pl-8 pr-8 py-2 rounded-xl border border-slate-200 bg-white text-sm text-slate-700 placeholder:text-slate-300 outline-none focus:border-emerald-400 focus:ring-2 focus:ring-emerald-50 transition">
                <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <% if (search) { %>
                    <a href="/admin/pickups?tab=<%= activeTab %>" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-300 hover:text-rose-400 text-xs transition">✕</a>
                <% } %>
            </div>
            <button type="submit" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold rounded-xl transition">Cari</button>
        </form>
    </div>

    <!-- Tabs -->
    <div class="flex items-center gap-1 flex-shrink-0 bg-slate-100/70 p-1 rounded-xl w-fit">
        <% tabs.forEach(tab => { %>
            <a href="/admin/pickups?tab=<%= tab.key %><%= search ? '&search=' + search : '' %>"
                class="flex items-center gap-2 px-4 py-1.5 rounded-lg text-xs font-bold transition
                    <%= activeTab === tab.key ? 'bg-white text-slate-800 shadow-sm' : 'text-slate-500 hover:text-slate-700' %>">
                <span class="h-2 w-2 rounded-full flex-shrink-0" style="background:<%= tab.dot %>"></span>
                <%= tab.label %>
                <span class="text-[10px] font-black <%= activeTab === tab.key ? 'text-slate-500' : 'text-slate-400' %>">
                    (<%= tab.count %>)
                </span>
            </a>
        <% }) %>
    </div>

    <!-- Table -->
    <div class="flex-1 min-h-0 bg-white rounded-2xl border border-slate-100 overflow-hidden flex flex-col">

        <!-- Table Head -->
        <div class="grid grid-cols-[3rem_1.5fr_1.5fr_1fr_0.8fr_<%= activeTab !== 'completed' ? '11rem' : '6rem' %>] gap-4 px-6 py-4 bg-slate-50/80 border-b border-slate-100 flex-shrink-0">
            <span class="text-[10px] font-black uppercase tracking-[0.15em] text-slate-400">ID</span>
            <span class="text-[10px] font-black uppercase tracking-[0.15em] text-slate-400">Pengguna & Tanggal</span>
            <span class="text-[10px] font-black uppercase tracking-[0.15em] text-slate-400">Alamat Penjemputan</span>
            <span class="text-[10px] font-black uppercase tracking-[0.15em] text-slate-400">Jenis Sampah</span>
            <span class="text-[10px] font-black uppercase tracking-[0.15em] text-slate-400">Estimasi</span>
            <span class="text-[10px] font-black uppercase tracking-[0.15em] text-slate-400 text-right">Tindakan</span>
        </div>

        <!-- Table Body -->
        <div class="flex-1 overflow-y-auto slim-scroll">
            <% if (rows.length === 0) { %>
                <div class="flex flex-col items-center justify-center h-full min-h-[300px] text-slate-400 bg-slate-50/30">
                    <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-3xl mb-4 shadow-sm border border-slate-100">
                        <%= activeTab === 'pending' ? '📭' : activeTab === 'on_the_way' ? '🚛' : '📦' %>
                    </div>
                    <p class="text-sm font-bold text-slate-600">
                        <%= search ? 'Tidak ada hasil untuk "' + search + '"' : 'Belum ada data di kategori ini.' %>
                    </p>
                </div>
            <% } else { %>
                <div class="divide-y divide-slate-50/80">
                <% rows.forEach(p => { %>
                    <div class="tbl-row grid grid-cols-[3rem_1.5fr_1.5fr_1fr_0.8fr_<%= activeTab !== 'completed' ? '11rem' : '6rem' %>] gap-4 px-6 py-4 items-center transition-all hover:bg-emerald-50/30 group">
                        
                        <!-- ID -->
                        <span class="text-xs font-black text-slate-300 group-hover:text-emerald-400 transition-colors">#<%= p.id %></span>

                        <!-- User -->
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="h-9 w-9 rounded-[10px] bg-gradient-to-br from-emerald-100 to-teal-50 border border-emerald-200/50 flex items-center justify-center text-[13px] font-black text-emerald-700 shadow-sm flex-shrink-0 group-hover:scale-105 transition-transform">
                                <%= p.user.username.charAt(0).toUpperCase() %>
                            </div>
                            <div class="min-w-0 space-y-0.5">
                                <p class="text-sm font-extrabold text-slate-800 truncate group-hover:text-emerald-700 transition-colors"><%= p.user.username %></p>
                                <div class="flex items-center gap-1.5 text-[10px] text-slate-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                    </svg>
                                    <span class="font-medium"><%= new Date(p.created_at).toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %></span>
                                </div>
                            </div>
                        </div>

                        <!-- Alamat -->
                        <div class="min-w-0 pr-4">
                            <p class="text-xs text-slate-600 font-medium leading-relaxed line-clamp-2" title="<%= p.pickup_address %>">
                                <%= p.pickup_address %>
                            </p>
                        </div>

                        <!-- Jenis -->
                        <div class="flex flex-wrap gap-1.5">
                            <% p.waste_types.split(',').forEach(type => { %>
                                <span class="px-2 py-1 rounded-md bg-slate-100 text-[10px] font-bold text-slate-600 capitalize"><%= type.trim() %></span>
                            <% }) %>
                        </div>

                        <!-- Berat -->
                        <div>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-emerald-50 border border-emerald-100 text-xs font-black text-emerald-700">
                                ⚖️ <%= p.weight_estimate %>
                            </span>
                        </div>

                        <!-- Aksi -->
                        <div class="flex items-center justify-end gap-2">
                            <% if (activeTab === 'pending') { %>
                                <form action="/admin/pickups/<%= p.id %>/status" method="POST" class="w-full sm:w-auto">
                                    <input type="hidden" name="status" value="on_the_way">
                                    <input type="hidden" name="redirect_tab" value="pending">
                                    <button type="submit" class="w-full px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-xs font-black rounded-[10px] shadow-sm shadow-blue-200 hover:shadow-md hover:-translate-y-0.5 transition-all whitespace-nowrap">
                                        Terima & OTW
                                    </button>
                                </form>
                            <% } else if (activeTab === 'on_the_way') { %>
                                <form action="/admin/pickups/<%= p.id %>/status" method="POST" class="w-full sm:w-auto">
                                    <input type="hidden" name="status" value="completed">
                                    <input type="hidden" name="redirect_tab" value="on_the_way">
                                    <button type="submit" class="w-full px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-black rounded-[10px] shadow-sm shadow-emerald-200 hover:shadow-md hover:-translate-y-0.5 transition-all whitespace-nowrap">
                                        Selesai ✓
                                    </button>
                                </form>
                                <form action="/admin/pickups/<%= p.id %>/status" method="POST" class="flex-shrink-0">
                                    <input type="hidden" name="status" value="pending">
                                    <input type="hidden" name="redirect_tab" value="on_the_way">
                                    <button type="submit" title="Batalkan / Kembalikan ke Menunggu" class="p-2 bg-white border border-slate-200 hover:border-rose-300 hover:bg-rose-50 text-slate-400 hover:text-rose-500 rounded-[10px] shadow-sm transition-all">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                                        </svg>
                                    </button>
                                </form>
                            <% } else { %>
                                <a href="/pickup/<%= p.id %>" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-xs font-black rounded-[10px] transition-colors whitespace-nowrap">
                                    Detail
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Footer info -->
        <div class="flex-shrink-0 px-4 py-2.5 border-t border-slate-50 flex items-center justify-between">
            <p class="text-[10px] text-slate-400 font-medium">
                Menampilkan <%= rows.length %> dari
                <% if (activeTab === 'pending') { %><%= totalPending %>
                <% } else if (activeTab === 'on_the_way') { %><%= totalOnTheWay %>
                <% } else { %><%= totalCompleted %><% } %> data
            </p>
            <% if (activeTab === 'completed' && totalCompleted > 30 && !search) { %>
                <p class="text-[10px] text-slate-400 font-medium">Hanya menampilkan 30 terbaru</p>
            <% } %>
        </div>
    </div>

</section>
