<section class="max-w-2xl mx-auto">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-white p-8 shadow-[0_20px_60px_rgba(34,197,94,0.12)] border border-emerald-100 lg:p-12">
        <!-- Decoration -->
        <div class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-emerald-50 blur-2xl"></div>
        <div class="absolute -left-10 -bottom-10 h-32 w-32 rounded-full bg-lime-50 blur-2xl"></div>

        <div class="relative">
            <div class="flex items-center gap-4 mb-8">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-600 text-white shadow-lg shadow-emerald-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Track Your Impact</h1>
                    <p class="text-sm font-medium text-slate-500 italic">Setiap kilogram sampah terpilah adalah langkah nyata untuk bumi.</p>
                </div>
            </div>
            
            <form id="wasteTrackForm" action="/waste/track" method="POST" enctype="multipart/form-data" class="space-y-8">
                <div class="grid gap-6">
                    <div class="rounded-2xl bg-emerald-50 p-6 border border-emerald-100">
                        <div class="flex items-center gap-3 mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                            <h3 class="font-bold text-emerald-900">AI-Powered Detection Active</h3>
                        </div>
                        <p class="text-xs text-emerald-700 leading-relaxed">Sistem AI kami akan secara otomatis mendeteksi berbagai jenis sampah (plastik, kertas, logam, dll) dari foto yang Anda unggah. Anda tidak perlu memilih jenis sampah secara manual lagi!</p>
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-3">Estimasi Total Berat (kg)</label>
                        <div class="relative group">
                            <input type="number" step="0.1" name="weight" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50/50 text-slate-900 font-bold placeholder:text-slate-300 focus:ring-4 focus:ring-emerald-100 focus:border-emerald-500 focus:outline-none transition group-hover:bg-white" placeholder="e.g., 2.5" required>
                            <div class="absolute inset-y-0 right-5 flex items-center">
                                <span class="text-sm font-black text-slate-300 uppercase tracking-widest">kg</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-3">Bukti Foto</label>
                        <div class="relative">
                            <input type="file" name="photo" accept="image/*" class="w-full cursor-pointer rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50/30 px-5 py-8 text-center text-sm font-bold text-slate-500 transition hover:border-emerald-300 hover:bg-emerald-50/50" required>
                        </div>
                        <p class="mt-3 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-center">* Pastikan semua jenis sampah terlihat jelas dalam satu foto.</p>
                    </div>
                </div>

                <button id="submitBtn" type="submit" class="w-full group relative flex items-center justify-center gap-3 overflow-hidden rounded-2xl bg-emerald-600 px-8 py-5 font-black text-white shadow-xl shadow-emerald-200 transition active:scale-[0.98]">
                    <span class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-lime-500 opacity-0 transition group-hover:opacity-100"></span>
                    <span class="relative">Analisis AI & Kirim Laporan</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center bg-slate-950/80 backdrop-blur-md p-6 text-center text-white">
        <div class="relative mb-8">
            <div class="h-24 w-24 rounded-full border-4 border-emerald-500/20"></div>
            <div class="absolute inset-0 h-24 w-24 animate-spin rounded-full border-4 border-t-emerald-500"></div>
            <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-400 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
            </div>
        </div>
        <h3 class="text-2xl font-black tracking-tight mb-2">AI sedang menganalisis foto...</h3>
        <p class="max-w-xs text-sm font-medium text-emerald-100/70 leading-relaxed">Mohon tunggu sebentar, sistem sedang memilah jenis sampah Anda secara otomatis.</p>
    </div>

    <script>
        const form = document.getElementById('wasteTrackForm');
        const submitBtn = document.getElementById('submitBtn');
        const loadingOverlay = document.getElementById('loadingOverlay');

        form.addEventListener('submit', () => {
            // Show loading screen
            loadingOverlay.classList.remove('hidden');
            loadingOverlay.classList.add('flex');
            
            // Disable button to prevent multiple submissions
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            submitBtn.innerHTML = 'Memproses...';
        });
    </script>
        </div>
    </div>
</section>
