<section class="max-w-2xl mx-auto">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-white p-8 shadow-[0_20px_60px_rgba(34,197,94,0.12)] border border-emerald-100 lg:p-12">
        <!-- Decoration -->
        <div class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-emerald-50 blur-2xl"></div>
        <div class="absolute -left-10 -bottom-10 h-32 w-32 rounded-full bg-lime-50 blur-2xl"></div>

        <div class="relative">
            <div class="flex items-center gap-4 mb-8">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-600 text-white shadow-lg shadow-emerald-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Track Your Impact</h1>
                    <p class="text-sm font-medium text-slate-500 italic">Setiap kilogram sampah terpilah adalah langkah nyata untuk bumi.</p>
                </div>
            </div>
            
            <form action="/waste/track" method="POST" enctype="multipart/form-data" class="space-y-8">
                <div class="grid gap-6">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-3">Jenis Sampah</label>
                        <div class="relative" id="wasteTypeDropdown">
                            <!-- Hidden input to store the actual value -->
                            <input type="hidden" name="waste_type" id="selectedWasteType" required>
                            
                            <!-- Search & Selected View -->
                            <div class="relative group">
                                <input type="text" id="wasteSearch" placeholder="Cari jenis sampah..." 
                                    class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50/50 text-slate-900 font-bold focus:ring-4 focus:ring-emerald-100 focus:border-emerald-500 focus:outline-none transition group-hover:bg-white pr-12">
                                <div class="absolute inset-y-0 right-5 flex items-center text-slate-400 pointer-events-none">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                            </div>

                            <!-- Dropdown Options -->
                            <div id="dropdownOptions" class="absolute z-50 mt-2 w-full max-h-64 overflow-y-auto rounded-2xl bg-white border border-slate-100 shadow-2xl hidden scrollbar-hide">
                                <% const wasteTypes = [
                                    "Sampah Organik", "Sampah Non-Organik", "Sampah Plastik", "Sampah Kertas", 
                                    "Sampah Kaca", "Sampah Logam", "Sampah Elektronik (E-Waste)", 
                                    "Sampah B3 (Bahan Berbahaya & Beracun)", "Sampah Medis", "Sampah Tekstil / Kain", 
                                    "Sampah Rumah Tangga", "Sampah Industri", "Sampah Residu", "Sampah Daur Ulang", 
                                    "Sampah Basah", "Sampah Kering", "Sampah Kebun / Daun", "Sampah Makanan", 
                                    "Sampah Bangunan / Konstruksi", "Sampah Campuran"
                                ]; %>
                                <% wasteTypes.forEach(type => { %>
                                    <div class="option-item px-6 py-4 hover:bg-emerald-50 cursor-pointer transition text-slate-700 font-bold" data-value="<%= type %>">
                                        <%= type %>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>

                    <script>
                        const searchInput = document.getElementById('wasteSearch');
                        const dropdownOptions = document.getElementById('dropdownOptions');
                        const hiddenInput = document.getElementById('selectedWasteType');
                        const options = document.querySelectorAll('.option-item');

                        // Show dropdown on focus
                        searchInput.addEventListener('focus', () => {
                            dropdownOptions.classList.remove('hidden');
                        });

                        // Filter options
                        searchInput.addEventListener('input', (e) => {
                            const term = e.target.value.toLowerCase();
                            options.forEach(opt => {
                                const text = opt.textContent.trim().toLowerCase();
                                if (text.includes(term)) {
                                    opt.classList.remove('hidden');
                                } else {
                                    opt.classList.add('hidden');
                                }
                            });
                        });

                        // Select option
                        options.forEach(opt => {
                            opt.addEventListener('click', () => {
                                const val = opt.getAttribute('data-value');
                                searchInput.value = val;
                                hiddenInput.value = val;
                                dropdownOptions.classList.add('hidden');
                            });
                        });

                        // Close dropdown when clicking outside
                        document.addEventListener('click', (e) => {
                            if (!document.getElementById('wasteTypeDropdown').contains(e.target)) {
                                dropdownOptions.classList.add('hidden');
                            }
                        });
                    </script>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-3">Estimasi Berat (kg)</label>
                        <div class="relative group">
                            <input type="number" step="0.1" name="weight" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50/50 text-slate-900 font-bold placeholder:text-slate-300 focus:ring-4 focus:ring-emerald-100 focus:border-emerald-500 focus:outline-none transition group-hover:bg-white" placeholder="e.g., 2.5" required>
                            <div class="absolute inset-y-0 right-5 flex items-center">
                                <span class="text-sm font-black text-slate-300 uppercase tracking-widest">kg</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-3">Bukti Foto</label>
                        <div class="relative">
                            <input type="file" name="photo" accept="image/*" class="w-full cursor-pointer rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50/30 px-5 py-8 text-center text-sm font-bold text-slate-500 transition hover:border-emerald-300 hover:bg-emerald-50/50" required>
                            <div class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center opacity-0 transition group-hover:opacity-100">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        </div>
                        <p class="mt-3 text-[10px] font-bold uppercase tracking-widest text-slate-400 text-center">* Foto yang jelas membantu proses verifikasi admin lebih cepat.</p>
                    </div>
                </div>

                <button type="submit" class="w-full group relative flex items-center justify-center gap-3 overflow-hidden rounded-2xl bg-emerald-600 px-8 py-5 font-black text-white shadow-xl shadow-emerald-200 transition active:scale-[0.98]">
                    <span class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-lime-500 opacity-0 transition group-hover:opacity-100"></span>
                    <span class="relative">Kirim Laporan & Klaim Poin</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="relative h-5 w-5 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</section>
