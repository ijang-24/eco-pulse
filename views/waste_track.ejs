<div class="max-w-2xl mx-auto bg-white p-10 rounded-3xl shadow-lg border border-gray-100">
    <h1 class="text-3xl font-bold mb-6 text-green-700">Waste Sorting Tracker</h1>
    <p class="text-gray-600 mb-8">Log your waste and earn Green Points. Every kilogram counts!</p>
    
    <form action="/waste/track" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Type of Waste</label>
            <select name="waste_type" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none">
                <option value="plastic">Plastic (Bottles, Bags)</option>
                <option value="paper">Paper (Carton, Newspaper)</option>
                <option value="metal">Metal (Cans, Foil)</option>
                <option value="glass">Glass (Bottles, Jars)</option>
                <option value="organic">Organic (Food Waste)</option>
            </select>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Estimated Weight (kg)</label>
            <input type="number" step="0.1" name="weight" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none" placeholder="e.g., 2.5" required>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Proof Photo</label>
            <input type="file" name="photo" accept="image/*" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-green-500 focus:outline-none" required>
            <p class="text-xs text-gray-400 mt-1 italic">* Please upload a clear photo of your sorted waste for verification.</p>
        </div>
        <button type="submit" class="w-full bg-green-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-green-700 transition shadow-lg shadow-green-100">Submit Log & Earn Points</button>
    </form>
</div>
