<section class="space-y-8">
    <!-- Header Section -->
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-emerald-600 via-emerald-500 to-lime-400 p-8 text-white shadow-[0_20px_50px_rgba(34,197,94,0.15)] lg:p-12">
        <div class="absolute -right-10 top-10 h-40 w-40 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
            <div>
                <p class="inline-flex rounded-full bg-white/15 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-white ring-1 ring-white/30">Citizen Dashboard</p>
                <h1 class="mt-4 text-4xl font-extrabold tracking-tight lg:text-5xl">Welcome back, <span class="text-lime-200"><%= user.username %>!</span></h1>
                <p class="mt-2 text-emerald-50/90 font-medium">Anda telah berkontribusi aktif dalam menjaga kebersihan RT <%= user.rt %> / RW <%= user.rw %>.</p>
            </div>
            <a href="/waste/track" class="group flex items-center gap-3 rounded-2xl bg-white px-6 py-4 font-bold text-emerald-700 shadow-xl transition hover:bg-emerald-50 hover:scale-[1.02] active:scale-[0.98]">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-100 group-hover:bg-emerald-200 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </span>
                Track New Waste
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Points Card -->
        <div class="group relative rounded-[2rem] border border-emerald-100 bg-white p-8 shadow-[0_15px_40px_rgba(34,197,94,0.06)] transition hover:shadow-[0_20px_50px_rgba(34,197,94,0.1)]">
            <div class="flex items-center justify-between">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600 transition group-hover:bg-emerald-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <span class="text-xs font-bold uppercase tracking-widest text-emerald-500">Total Points</span>
            </div>
            <p class="mt-6 text-5xl font-extrabold tracking-tight text-slate-900"><%= user.total_points || 0 %></p>
            <p class="mt-2 text-sm font-medium text-slate-500">Green Points earned</p>
        </div>

        <!-- CO2 Card -->
        <div class="group relative rounded-[2rem] border border-orange-100 bg-white p-8 shadow-[0_15px_40px_rgba(249,115,22,0.06)] transition hover:shadow-[0_20px_50px_rgba(249,115,22,0.1)]">
            <div class="flex items-center justify-between">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-orange-50 text-orange-600 transition group-hover:bg-orange-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <span class="text-xs font-bold uppercase tracking-widest text-orange-500">CO2 Reduced</span>
            </div>
            <div class="mt-6 flex items-baseline gap-2">
                <p class="text-5xl font-extrabold tracking-tight text-slate-900"><%= impact.co2 %></p>
                <p class="text-lg font-bold text-slate-400">kg</p>
            </div>
            <p class="mt-2 text-sm font-medium text-slate-500">Estimated emission saved</p>
        </div>

        <!-- Trees Card -->
        <div class="group relative rounded-[2rem] border border-sky-100 bg-white p-8 shadow-[0_15px_40px_rgba(14,165,233,0.06)] transition hover:shadow-[0_20px_50px_rgba(14,165,233,0.1)]">
            <div class="flex items-center justify-between">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-50 text-sky-600 transition group-hover:bg-sky-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z" />
                    </svg>
                </div>
                <span class="text-xs font-bold uppercase tracking-widest text-sky-500">Trees Saved</span>
            </div>
            <p class="mt-6 text-5xl font-extrabold tracking-tight text-slate-900"><%= impact.trees %></p>
            <p class="mt-2 text-sm font-medium text-slate-500">Visualized eco-impact</p>
        </div>
    </div>

    <!-- Waste Logs Section -->
    <div class="rounded-[2.5rem] border border-emerald-100 bg-white/95 p-8 shadow-[0_20px_60px_rgba(34,197,94,0.08)] backdrop-blur-xl lg:p-10">
        <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h2 class="text-3xl font-extrabold text-slate-900">Recent Waste Logs</h2>
                <p class="mt-1 text-sm font-medium text-slate-500 italic">Tracking your 5 latest contributions to the community.</p>
            </div>
            <a href="/waste/track" class="text-sm font-bold text-emerald-600 hover:text-emerald-700 hover:underline transition">View all activity &rarr;</a>
        </div>

        <% if (logs && logs.length > 0) { %>
            <div class="grid gap-4">
                <% logs.forEach(log => { %>
                    <div class="group flex flex-col gap-6 rounded-3xl border border-slate-100 bg-white p-6 transition hover:border-emerald-200 hover:shadow-md lg:flex-row lg:items-center lg:justify-between lg:p-4">
                        <div class="flex items-center gap-5">
                            <div class="relative shrink-0 overflow-hidden rounded-2xl bg-slate-100 shadow-inner">
                                <% if (log.photo_url) { %>
                                    <img src="<%= log.photo_url %>" alt="Proof" class="h-20 w-20 object-cover transition group-hover:scale-110">
                                <% } else { %>
                                    <div class="flex h-20 w-20 items-center justify-center text-slate-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                <% } %>
                            </div>
                            <div>
                                <div class="flex items-center gap-2">
                                    <p class="text-lg font-extrabold capitalize text-slate-900"><%= log.waste_type %> Waste</p>
                                    <span class="rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider 
                                        <%= log.status === 'verified' ? 'bg-emerald-100 text-emerald-700' : 
                                           log.status === 'rejected' ? 'bg-rose-100 text-rose-700' : 'bg-amber-100 text-amber-700' %>">
                                        <%= log.status %>
                                    </span>
                                </div>
                                <p class="mt-1 text-sm font-medium text-slate-500">
                                    <span class="text-slate-900 font-bold"><%= log.weight %> kg</span> 
                                    <span class="mx-2 text-slate-300">•</span> 
                                    <%= new Date(log.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center justify-between border-t border-slate-50 pt-4 lg:border-none lg:pt-0">
                            <div class="text-right">
                                <p class="text-xl font-black text-emerald-600">+<%= log.points_earned %></p>
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Green Points</p>
                            </div>
                            <button class="ml-6 hidden h-10 w-10 items-center justify-center rounded-xl bg-slate-50 text-slate-400 transition hover:bg-emerald-50 hover:text-emerald-600 lg:flex">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                </svg>
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="flex h-20 w-20 items-center justify-center rounded-[2rem] bg-slate-50 text-slate-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <h3 class="mt-6 text-xl font-extrabold text-slate-900">Belum ada kontribusi</h3>
                <p class="mt-2 max-w-sm text-sm leading-6 text-slate-500">Mulai perjalanan hijau Anda hari ini dengan mencatat sampah terpilah pertama Anda.</p>
                <a href="/waste/track" class="mt-6 rounded-2xl bg-emerald-600 px-8 py-3.5 text-sm font-bold text-white shadow-lg shadow-emerald-100 transition hover:bg-emerald-700">Mulai Tracking</a>
            </div>
        <% } %>
    </div>
</section>
