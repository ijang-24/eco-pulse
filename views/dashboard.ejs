<div class="grid gap-8 xl:grid-cols-[1.15fr_0.85fr]">
    <section class="rounded-[2.5rem] bg-gradient-to-br from-emerald-400 via-lime-300 to-sky-300 p-8 text-slate-900 shadow-[0_24px_80px_rgba(34,197,94,0.20)] lg:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Citizen Dashboard</p>
        <div class="mt-5 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <h1 class="text-4xl font-extrabold leading-tight lg:text-5xl">Halo, <%= user.username %>.</h1>
                <p class="mt-4 max-w-2xl text-base leading-7 text-slate-700">
                    Pantau kontribusi Anda, cek status verifikasi log, dan lihat bagaimana aksi kecil di lingkungan bisa berubah menjadi progres komunitas yang terukur.
                </p>
            </div>
            <a href="/waste/track" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3.5 text-sm font-bold text-emerald-700 shadow-lg transition hover:bg-emerald-50">+ Buat Log Baru</a>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/35 bg-white/45 p-5 backdrop-blur-sm">
                <p class="text-sm text-emerald-700">Total Points</p>
                <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= user.total_points || 0 %></p>
            </div>
            <div class="rounded-2xl border border-white/35 bg-white/45 p-5 backdrop-blur-sm">
                <p class="text-sm text-emerald-700">Neighborhood</p>
                <p class="mt-2 text-3xl font-extrabold text-slate-900">RT <%= user.rt %></p>
                <p class="text-sm text-slate-600">RW <%= user.rw %></p>
            </div>
            <div class="rounded-2xl border border-white/35 bg-white/45 p-5 backdrop-blur-sm">
                <p class="text-sm text-emerald-700">Account Role</p>
                <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= user.role === 'admin' ? 'Admin' : 'Citizen' %></p>
            </div>
        </div>
    </section>

    <aside class="rounded-[2rem] border border-slate-200/80 bg-white/95 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.08)] backdrop-blur">
        <% if (user.role === 'admin') { %>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-amber-700">Admin Access</p>
            <div class="mt-6 space-y-4">
                <div class="rounded-2xl bg-amber-50 p-5">
                    <p class="font-bold text-amber-900">Akun ini juga punya panel admin</p>
                    <p class="mt-2 text-sm leading-6 text-amber-800">Untuk review kontribusi warga, gunakan area admin yang punya tampilan dan workflow khusus.</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-5">
                    <p class="font-bold text-slate-900">Masuk ke mode admin</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">Buka panel verifikasi untuk approve, reject, atau hapus log warga secara terpisah dari dashboard user.</p>
                    <a href="/admin/dashboard" class="mt-4 inline-flex rounded-full bg-slate-900 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800">Open Admin Panel</a>
                </div>
            </div>
        <% } else { %>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Contribution Rules</p>
            <div class="mt-6 space-y-4">
                <div class="rounded-2xl bg-amber-50 p-5">
                    <p class="font-bold text-amber-900">Pending belum menambah poin</p>
                    <p class="mt-2 text-sm leading-6 text-amber-800">Poin resmi baru masuk setelah log Anda diverifikasi oleh admin.</p>
                </div>
                <div class="rounded-2xl bg-emerald-50 p-5">
                    <p class="font-bold text-emerald-900">Verified menambah total impact</p>
                    <p class="mt-2 text-sm leading-6 text-emerald-800">Log yang disetujui akan langsung memengaruhi total poin Anda.</p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-5">
                    <p class="font-bold text-slate-900">Gunakan foto yang jelas</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">Bukti yang rapi mempercepat proses review dan mengurangi risiko penolakan.</p>
                </div>
            </div>
        <% } %>
    </aside>
</div>

<section class="mt-8 rounded-[2rem] border border-slate-200/80 bg-white/95 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.08)] backdrop-blur">
    <div class="mb-8 flex flex-col gap-4 border-b border-slate-100 pb-6 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-600">Recent Activity</p>
            <h2 class="mt-2 text-3xl font-extrabold text-slate-900">Riwayat log sampah Anda</h2>
        </div>
        <a href="/waste/track" class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-5 py-3 text-sm font-bold text-emerald-700 transition hover:bg-emerald-100">Tambah Log</a>
    </div>

    <% if (logs && logs.length > 0) { %>
        <div class="grid gap-5">
            <% logs.forEach(log => { %>
                <article class="grid gap-5 rounded-[1.75rem] border border-slate-200/80 bg-slate-50/80 p-5 md:grid-cols-[96px_1fr_auto] md:items-center">
                    <div>
                        <% if (log.photo_url) { %>
                            <img src="<%= log.photo_url %>" alt="Proof" class="h-24 w-24 rounded-2xl border border-slate-200 object-cover shadow-sm">
                        <% } else { %>
                            <div class="flex h-24 w-24 items-center justify-center rounded-2xl border border-dashed border-slate-200 bg-white text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">No Photo</div>
                        <% } %>
                    </div>

                    <div>
                        <div class="flex flex-wrap items-center gap-3">
                            <h3 class="text-xl font-extrabold capitalize text-slate-900"><%= log.waste_type %> Waste</h3>
                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold capitalize
                                <%= log.status === 'verified' ? 'bg-green-100 text-green-700' : log.status === 'rejected' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>">
                                <%= log.status === 'pending' ? 'pending review' : log.status %>
                            </span>
                        </div>
                        <p class="mt-2 text-sm leading-6 text-slate-500"><%= log.weight %> kg submitted on <%= new Date(log.created_at).toLocaleDateString() %></p>
                        <p class="mt-1 text-sm leading-6 text-slate-500">Log ini akan dihitung ke total poin setelah diverifikasi admin.</p>
                    </div>

                    <div class="md:text-right">
                        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-400">Potential Points</p>
                        <p class="mt-2 text-3xl font-extrabold text-emerald-700"><%= log.status === 'verified' ? '+' : '' %><%= log.points_earned %></p>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } else { %>
        <div class="rounded-[2rem] border border-dashed border-slate-300 bg-slate-50 px-6 py-16 text-center">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-400">No Activity Yet</p>
            <h3 class="mt-3 text-2xl font-extrabold text-slate-900">Anda belum punya log sampah.</h3>
            <p class="mt-3 text-sm leading-6 text-slate-500">Mulai dari satu log pertama agar dashboard ini berisi progres nyata yang bisa diverifikasi admin.</p>
        </div>
    <% } %>
</section>
