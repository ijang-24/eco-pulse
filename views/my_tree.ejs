<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:'Nunito',sans-serif; }

    body {
      min-height:100vh; overflow:hidden;
      background:#d4f0f0; user-select:none;
    }

    /* ── SKY ── */
    .sky {
      position:absolute; inset:0;
      background:linear-gradient(180deg,#9ae2f2 0%,#c4f4f4 40%,#fdfde3 80%,#e1f4cd 100%);
      z-index:1;
    }
    .sun {
      position:absolute; top:9%; right:14%; width:110px; height:110px;
      border-radius:50%;
      background:radial-gradient(circle,#fffbe0 0%,#ffdf73 50%,#ffb84d 100%);
      box-shadow:0 0 55px rgba(255,223,115,.8),0 0 110px rgba(255,184,77,.4);
      animation:pulseSun 6s ease-in-out infinite; z-index:2;
    }
    @keyframes pulseSun{0%,100%{transform:scale(1);opacity:.9}50%{transform:scale(1.05);opacity:1}}

    /* ── CLOUDS ── */
    .cloud {
      position:absolute; background:white; border-radius:100px;
      box-shadow:0 8px 16px rgba(0,0,0,.05);
      animation:drift linear infinite; opacity:.9;
    }
    .cloud::before,.cloud::after{content:'';position:absolute;background:white;border-radius:50%;}
    @keyframes drift{from{transform:translateX(-220px)}to{transform:translateX(110vw)}}

    /* ── PARALLAX LAYERS ── */
    .layer {
      position:absolute; top:0; left:-5%; width:110%; height:100%;
      pointer-events:none;
      transition:transform .18s cubic-bezier(.25,.46,.45,.94);
      display:flex; flex-direction:column; justify-content:flex-end; align-items:center;
    }
    .layer-bg  { z-index:2; }
    .layer-mid { z-index:3; }
    .layer-front{ z-index:4; }
    .layer-ui  { z-index:10; pointer-events:auto; justify-content:flex-start; left:0; width:100%; padding:20px; }

    /* hills */
    .hill          { position:absolute; bottom:0; width:100%; }
    .hill-bg       { fill:#a2db96; filter:drop-shadow(0 -10px 20px rgba(162,219,150,.4)); }
    .hill-mid      { fill:#86c97a; filter:drop-shadow(0 -5px 15px rgba(134,201,122,.3)); }
    .ground-base   { fill:#65b058; }

    .base-shadow {
      width:280px; height:38px; border-radius:50%;
      background:radial-gradient(ellipse,rgba(46,102,36,.55) 0%,rgba(46,102,36,0) 70%);
      margin-bottom:-18px; z-index:1; filter:blur(5px);
    }

    /* ── TREE ── */
    .tree-container {
      position:relative; z-index:5; pointer-events:auto; cursor:pointer;
      display:flex; flex-direction:column; align-items:center;
      transform-origin:bottom center;
      animation:treeBreathe 8s ease-in-out infinite;
      margin-bottom:40px;
    }
    .tree-container:hover { filter:brightness(1.05) saturate(1.1); }
    .tree-container:active{ transform:scale(.97); transition:transform .1s; }
    @keyframes treeBreathe{
      0%,100%{transform:scaleY(1) rotate(0deg)}
      25%    {transform:scaleY(1.015) rotate(.7deg)}
      75%    {transform:scaleY(1.008) rotate(-.5deg)}
    }
    svg { overflow:visible; display:block; }

    /* ── GLASSMORPHISM ── */
    .glass-card {
      background:rgba(255,255,255,.6);
      backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
      border:2px solid rgba(255,255,255,.8); border-radius:32px;
      box-shadow:0 20px 50px rgba(0,0,0,.08),inset 0 2px 4px rgba(255,255,255,.8);
      padding:24px 32px; color:#064e3b; transition:all .3s ease;
    }

    /* ── TOP BAR ── */
    .top-bar{display:flex;justify-content:center;align-items:flex-start;width:100%;max-width:1200px;margin:0 auto;gap:20px; margin-top: 80px;}

    /* stage tracker */
    .stage-tracker{display:flex;align-items:center;gap:14px;padding:14px 28px;}
    .stage-item{display:flex;flex-direction:column;align-items:center;gap:6px;}
    .stage-icon{font-size:1.5rem;filter:grayscale(1);opacity:.4;transition:all .5s cubic-bezier(.34,1.56,.64,1);transform:scale(.8);}
    .stage-icon.active{filter:grayscale(0);opacity:1;transform:scale(1.3);filter:drop-shadow(0 4px 8px rgba(0,0,0,.15));}
    .stage-dot{width:10px;height:10px;border-radius:50%;background:rgba(0,0,0,.1);border:2px solid transparent;transition:all .5s;}
    .stage-dot.active{background:#34d399;border-color:#fff;box-shadow:0 0 12px rgba(52,211,153,.6);}
    .stage-line{width:24px;height:4px;border-radius:2px;background:rgba(0,0,0,.06);transition:all .5s;}
    .stage-line.active{background:linear-gradient(90deg,#34d399,#10b981);}

    /* ── CENTER HUD ── */
    .bottom-hud{position:absolute;top:55%;left:40px;transform:translateY(-50%);width:auto;display:flex;justify-content:flex-start;pointer-events:none;z-index:20;}
    .stats-panel{width:380px;pointer-events:auto;display:flex;flex-direction:column;gap:16px;}

    @media(max-width:768px){
      .mobile-hide-title { display: none!important; }
      .layer-front{justify-content:center!important; padding-bottom:80px!important;}
      .bottom-hud{left:0;right:0;top:auto;transform:none;width:100%;bottom:12px;justify-content:center;padding:0 15px;}
      .stats-panel{max-width:100%; padding: 12px 16px!important; border-radius: 20px; gap: 8px!important;}
      .stat-value{font-size: 1.6rem;}
      .tree-container{margin-bottom:0px!important;transform:scale(.72);}
      .ground-base{height:18vh!important;}
      .top-bar{margin-top: 80px!important; padding: 0 10px;}
      .stage-tracker{gap:8px; padding:10px 16px; border-radius: 20px;}
      .stage-line{width:14px; height:3px;}
      .stage-icon{font-size:1.1rem;}
      .stage-icon.active{transform:scale(1.2);}
      .stage-dot{width:8px; height:8px;}
      .cta-btn{padding: 12px 0!important; font-size: 14px!important; border-radius: 16px!important; margin-top: 4px!important;}
    }

    @media(max-width:400px){
      .layer-front{padding-bottom:60px!important;}
      .stage-tracker{gap:4px; padding:8px 12px;}
      .stage-line{width:8px;}
      .stage-icon{font-size:0.95rem;}
      .tree-container{transform:scale(.62); margin-bottom: 0px!important;}
      .bottom-hud{bottom: 8px;}
      .stats-panel{gap: 6px!important; padding: 10px 14px!important;}
      .stat-value{font-size: 1.35rem;}
      .cta-btn{padding: 10px 0!important; font-size: 13px!important; border-radius: 12px!important;}
    }

    .stat-row{display:flex;justify-content:space-between;align-items:flex-end;}
    .stat-label{font-size:11px;font-weight:900;letter-spacing:.2em;text-transform:uppercase;color:#059669;margin-bottom:4px;opacity:.8;}
    .stat-value{font-size:2.2rem;font-weight:900;line-height:1;color:#064e3b;filter:drop-shadow(0 2px 4px rgba(0,0,0,.05));}

    .progress-wrapper{background:rgba(0,0,0,.06);border-radius:99px;height:14px;overflow:hidden;box-shadow:inset 0 2px 4px rgba(0,0,0,.05);}
    .progress-fill{
      height:100%;border-radius:99px;width:0%;
      background:linear-gradient(90deg,#34d399,#10b981,#059669);
      box-shadow:inset 0 -2px 4px rgba(0,0,0,.1),inset 0 2px 4px rgba(255,255,255,.4);
      transition:width 1.5s cubic-bezier(.34,1.56,.64,1);
    }

    .cta-btn{
      background:linear-gradient(135deg,#34d399 0%,#10b981 100%);
      box-shadow:0 12px 30px rgba(16,185,129,.3),inset 0 2px 4px rgba(255,255,255,.4);
      color:white;font-weight:900;font-size:16px;letter-spacing:.05em;
      padding:18px 0;border-radius:24px;text-align:center;display:block;
      text-decoration:none;border:none;cursor:pointer;width:100%;
      transition:all .3s cubic-bezier(.34,1.56,.64,1);
      text-shadow:0 2px 4px rgba(0,0,0,.1);
    }
    .cta-btn:hover{transform:translateY(-5px) scale(1.02);box-shadow:0 20px 40px rgba(16,185,129,.4),inset 0 2px 4px rgba(255,255,255,.5);}
    .cta-btn:active{transform:translateY(0) scale(.98);}

    .fade-enter{opacity:0;animation:fadeIn .8s ease forwards;}
    @keyframes fadeIn{to{opacity:1}}

    /* ── PARTICLES ── */
    .particle{position:absolute;border-radius:50%;pointer-events:none;z-index:6;animation:floatUp linear forwards;}
    @keyframes floatUp{
      0%  {transform:translateY(0) scale(.8);opacity:0}
      20% {opacity:1}
      80% {opacity:.8}
      100%{transform:translateY(-100vh) scale(1.2);opacity:0}
    }

    /* ── SPARKLE (stage 5) ── */
    @keyframes sparkle{
      0%,100%{transform:scale(1);opacity:.7}
      50%{transform:scale(1.35) translateY(-3px);opacity:1}
    }
    /* sprout pop (stage 1) */
    @keyframes sproutPop{
      0%  {transform:scaleY(0);opacity:0}
      100%{transform:scaleY(1);opacity:1}
    }
  </style>
</head>
<body>

<div class="sky"></div>
<div class="sun"></div>
<div id="clouds" class="layer layer-bg" style="z-index:1;"></div>

<!-- BACK HILLS -->
<div class="layer layer-bg" id="parallax-bg">
  <svg class="hill hill-bg" viewBox="0 0 1440 320" preserveAspectRatio="none" style="height:40vh;transform:translateY(10%);">
    <path d="M0,160 C320,300 420,0 720,160 C1020,320 1120,50 1440,160 L1440,320 L0,320 Z"/>
  </svg>
</div>

<!-- MID HILLS -->
<div class="layer layer-mid" id="parallax-mid">
  <svg class="hill hill-mid" viewBox="0 0 1440 320" preserveAspectRatio="none" style="height:35vh;transform:translateY(5%);">
    <path d="M0,250 C220,100 450,300 720,200 C990,100 1200,280 1440,220 L1440,320 L0,320 Z"/>
  </svg>
</div>

<!-- FRONT GROUND & TREE -->
<div class="layer layer-front" id="parallax-front">
  <div class="tree-container" id="treeContainer">
    <!-- injected by JS -->
  </div>
  <div class="base-shadow" id="baseShadow"></div>
  <svg class="hill ground-base" viewBox="0 0 1440 160" preserveAspectRatio="none" style="height:18vh;position:absolute;bottom:0;z-index:-1;">
    <path d="M0,40 C320,80 420,0 720,40 C1020,80 1120,20 1440,50 L1440,160 L0,160 Z"/>
  </svg>
</div>

<!-- UI LAYER -->
<div class="layer layer-ui" id="parallax-ui">

  <div class="top-bar fade-enter">

    <div class="glass-card stage-tracker" style="padding:10px 24px;">
      <div class="stage-item" title="Stage 1">
        <span class="stage-icon" id="si1">🌰</span>
        <div class="stage-dot" id="sd1"></div>
      </div>
      <div class="stage-line" id="sl1"></div>
      <div class="stage-item" title="Stage 2">
        <span class="stage-icon" id="si2">🌱</span>
        <div class="stage-dot" id="sd2"></div>
      </div>
      <div class="stage-line" id="sl2"></div>
      <div class="stage-item" title="Stage 3">
        <span class="stage-icon" id="si3">🌿</span>
        <div class="stage-dot" id="sd3"></div>
      </div>
      <div class="stage-line" id="sl3"></div>
      <div class="stage-item" title="Stage 4">
        <span class="stage-icon" id="si4">🌲</span>
        <div class="stage-dot" id="sd4"></div>
      </div>
      <div class="stage-line" id="sl4"></div>
      <div class="stage-item" title="Stage 5">
        <span class="stage-icon" id="si5">🌳</span>
        <div class="stage-dot" id="sd5"></div>
      </div>
    </div>
  </div>

  <div class="bottom-hud fade-enter" style="animation-delay:.2s;">
    <div class="glass-card stats-panel">
      <div class="mobile-hide-title" style="text-align:center;margin-bottom:8px;">
        <p class="stat-label" style="letter-spacing:.3em;margin-bottom:2px;">✦ My Eco-Garden ✦</p>
        <h1 style="font-size:24px;font-weight:900;color:#064e3b;"><%= user.username %>'s <span style="color:#059669;">Tree</span></h1>
      </div>
      <div class="stat-row">
        <div>
          <p class="stat-label" id="stageLabel">Current Stage (<%= tree.stage %>/5)</p>
          <h2 style="font-size:1.5rem;font-weight:900;color:#064e3b;" id="stageName"><%= tree.stageName %></h2>
        </div>
        <div style="text-align:right;">
          <p class="stat-label">Total Sampah</p>
          <p class="stat-value" id="totalKg"><%= tree.totalWeight %><span style="font-size:14px;opacity:.6;margin-left:4px;">kg</span></p>
        </div>
      </div>
      <div>
        <p class="stat-label" style="margin-bottom:8px;">Nutrisi Pohon</p>
        <div class="progress-wrapper">
          <div class="progress-fill" id="nfill"></div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:8px;">
          <span style="font-size:12px;font-weight:700;color:#059669;opacity:.7;">0 kg</span>
          <span style="font-size:14px;font-weight:900;color:#059669;" id="pctLabel"><%= tree.progress %>%</span>
          <span style="font-size:12px;font-weight:700;color:#059669;opacity:.7;" id="nextTarget"><%= tree.nextTarget %> kg</span>
        </div>
      </div>
      <% if(tree.stage < 5) { %>
      <p style="font-size:13px;text-align:center;font-weight:600;color:#047857;margin-top:4px;" id="hintText">
        Setor <strong style="color:#059669;font-size:15px;"><%= (tree.nextTarget - tree.totalWeight).toFixed(1) %> kg</strong> lagi untuk evolusi 🌱
      </p>
      <% } else { %>
      <p style="font-size:14px;color:#b45309;text-align:center;font-weight:800;margin-top:4px;">🏆 Pohon Legendaris — Pencapaian Tertinggi!</p>
      <% } %>
      <a href="/waste/track" class="cta-btn" style="margin-top:8px;">💧 Siram Pohon (Setor Sampah)</a>
    </div>
  </div>

</div>

<script>
/* =========================================================
   SVG DEFS (shared)
========================================================= */
const DEFS = `<defs>
  <linearGradient id="bark" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%"   stop-color="#5c2d0a"/>
    <stop offset="20%"  stop-color="#8b4513"/>
    <stop offset="52%"  stop-color="#a0522d"/>
    <stop offset="80%"  stop-color="#8b4513"/>
    <stop offset="100%" stop-color="#4a1e08"/>
  </linearGradient>
  <linearGradient id="barkB" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%"   stop-color="#6d3410"/>
    <stop offset="45%"  stop-color="#7a3a14"/>
    <stop offset="100%" stop-color="#3d1a06"/>
  </linearGradient>
  <radialGradient id="lG1" cx="35%" cy="28%" r="70%">
    <stop offset="0%"   stop-color="#c8f5a0"/>
    <stop offset="42%"  stop-color="#6dcc40"/>
    <stop offset="100%" stop-color="#2d7a18"/>
  </radialGradient>
  <radialGradient id="lG2" cx="33%" cy="30%" r="72%">
    <stop offset="0%"   stop-color="#b0eecc"/>
    <stop offset="45%"  stop-color="#3dbf80"/>
    <stop offset="100%" stop-color="#1a6640"/>
  </radialGradient>
  <radialGradient id="lG3" cx="30%" cy="28%" r="70%">
    <stop offset="0%"   stop-color="#e0f8b0"/>
    <stop offset="40%"  stop-color="#88d420"/>
    <stop offset="100%" stop-color="#4a7810"/>
  </radialGradient>
  <radialGradient id="lGold" cx="33%" cy="28%" r="70%">
    <stop offset="0%"   stop-color="#fffbc0"/>
    <stop offset="45%"  stop-color="#f4c40a"/>
    <stop offset="100%" stop-color="#9a6800"/>
  </radialGradient>
  <radialGradient id="seedG" cx="35%" cy="30%" r="70%">
    <stop offset="0%"   stop-color="#d4a85a"/>
    <stop offset="50%"  stop-color="#a0642a"/>
    <stop offset="100%" stop-color="#6b3a10"/>
  </radialGradient>
  <radialGradient id="seedShell" cx="30%" cy="25%" r="75%">
    <stop offset="0%"   stop-color="#c8884a"/>
    <stop offset="60%"  stop-color="#8b5020"/>
    <stop offset="100%" stop-color="#5c2e08"/>
  </radialGradient>
  <filter id="sh">
    <feDropShadow dx="0" dy="9" stdDeviation="7" flood-color="#1a4a10" flood-opacity="0.28"/>
  </filter>
  <filter id="shS">
    <feDropShadow dx="0" dy="4" stdDeviation="4" flood-color="#1a4a10" flood-opacity="0.22"/>
  </filter>
  <filter id="shSeed">
    <feDropShadow dx="2" dy="6" stdDeviation="5" flood-color="#4a2800" flood-opacity="0.4"/>
  </filter>
  <filter id="glow">
    <feGaussianBlur stdDeviation="11" result="b"/>
    <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
  </filter>
</defs>`;

/* =========================================================
   STAGE BUILDERS
========================================================= */
function buildStage1() {
  return `<svg viewBox="0 0 320 270" width="320" height="270" style="overflow:visible">
  ${DEFS}
  <style>
    @keyframes sproutPop{0%{transform:scaleY(0);opacity:0}100%{transform:scaleY(1);opacity:1}}
  </style>
  <g filter="url(#shSeed)">
    <!-- Acorn nut body -->
    <ellipse cx="160" cy="170" rx="38" ry="46" fill="url(#seedG)"/>
    <!-- Acorn cap -->
    <ellipse cx="160" cy="131" rx="44" ry="20" fill="url(#seedShell)"/>
    <!-- Cap texture dots -->
    <circle cx="148" cy="129" r="3"   fill="rgba(60,20,0,.3)"/>
    <circle cx="160" cy="126" r="3"   fill="rgba(60,20,0,.3)"/>
    <circle cx="172" cy="129" r="3"   fill="rgba(60,20,0,.3)"/>
    <circle cx="143" cy="135" r="2.5" fill="rgba(60,20,0,.25)"/>
    <circle cx="177" cy="135" r="2.5" fill="rgba(60,20,0,.25)"/>
    <!-- Cap stem -->
    <rect x="157" y="111" width="6" height="14" rx="3" fill="#4a1e08"/>
    <!-- Nut highlight -->
    <ellipse cx="146" cy="151" rx="10" ry="14" fill="rgba(255,255,255,.18)" transform="rotate(-20,146,151)"/>
    <!-- Bottom crack -->
    <path d="M154,208 Q160,202 166,208" stroke="#3d1a06" stroke-width="2" stroke-linecap="round" fill="none"/>
    <!-- Tiny sprout stem -->
    <path d="M160,206 Q158,195 157,187"
          stroke="#3dbf80" stroke-width="3.5" stroke-linecap="round" fill="none"
          style="transform-origin:160px 210px;animation:sproutPop .8s .3s cubic-bezier(.34,1.56,.64,1) both"/>
    <!-- Tiny sprout leaf -->
    <ellipse cx="156" cy="185" rx="6" ry="9" fill="#6dcc40" transform="rotate(-25,156,185)"
             style="transform-origin:156px 195px;animation:sproutPop .8s .5s cubic-bezier(.34,1.56,.64,1) both"/>
  </g>
  <!-- Soil mound -->
  <ellipse cx="160" cy="220" rx="70" ry="16" fill="#5a3010" opacity=".52"/>
  <ellipse cx="160" cy="216" rx="66" ry="12" fill="#7a4520" opacity=".42"/>
  <ellipse cx="145" cy="213" rx="22" ry="5"  fill="rgba(180,120,60,.22)" transform="rotate(-8,145,213)"/>
</svg>`;
}

function buildStage2() {
  return `<svg viewBox="0 0 320 330" width="320" height="330" style="overflow:visible">
  ${DEFS}
  <!-- Soil mound -->
  <ellipse cx="160" cy="318" rx="68" ry="14" fill="#5a3010" opacity=".5"/>
  <ellipse cx="160" cy="314" rx="62" ry="10" fill="#7a4520" opacity=".38"/>
  <!-- Stem -->
  <path d="M156,320 C156,290 157,258 158,232 L162,232 C163,258 164,290 164,320 Z" fill="url(#bark)"/>
  <path d="M158,316 C158,285 159,252 159.5,234"
        stroke="rgba(200,130,70,.38)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
  <!-- Left leaf (teardrop, tilted) -->
  <g filter="url(#shS)">
    <path d="M158,248 C138,244 118,230 120,210 C122,190 143,186 155,197 C160,202 160,220 158,248 Z"
          fill="url(#lG2)"/>
    <path d="M158,244 C148,230 132,212 124,202"
          stroke="rgba(20,100,30,.32)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    <ellipse cx="138" cy="205" rx="9" ry="6" fill="rgba(255,255,255,.28)" transform="rotate(-40,138,205)"/>
  </g>
  <!-- Right leaf (mirrored) -->
  <g filter="url(#shS)">
    <path d="M162,248 C182,244 202,230 200,210 C198,190 177,186 165,197 C160,202 160,220 162,248 Z"
          fill="url(#lG1)"/>
    <path d="M162,244 C172,230 188,212 196,202"
          stroke="rgba(20,100,30,.32)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    <ellipse cx="182" cy="205" rx="9" ry="6" fill="rgba(255,255,255,.28)" transform="rotate(40,182,205)"/>
  </g>
  <!-- Top bud leaves -->
  <g filter="url(#shS)">
    <path d="M160,232 C151,228 145,217 149,208 C152,200 159,202 160,213 Z"
          fill="url(#lG1)" transform="rotate(-12,160,232)"/>
    <path d="M160,232 C169,228 175,217 171,208 C168,200 161,202 160,213 Z"
          fill="url(#lG2)" transform="rotate(12,160,232)"/>
  </g>
</svg>`;
}

function buildStage3() {
  const cx = 160;
  const flowers = [[cx-62,218],[cx+62,218],[cx,153],[cx-36,188],[cx+36,188],[cx-70,250],[cx+70,250]];
  return `<svg viewBox="0 0 320 420" width="320" height="420" style="overflow:visible">
  ${DEFS}
  <!-- Roots -->
  <path d="M148,406 Q138,390 126,380" stroke="url(#bark)" stroke-width="9"  stroke-linecap="round" fill="none"/>
  <path d="M172,406 Q182,390 194,380" stroke="url(#bark)" stroke-width="9"  stroke-linecap="round" fill="none"/>
  <!-- Trunk -->
  <path d="M148,410 C148,360 151,310 153,270 L167,270 C169,310 172,360 172,410 Z" fill="url(#bark)" filter="url(#shS)"/>
  <path d="M152,402 C152,354 153,306 154,273"
        stroke="rgba(180,100,50,.33)" stroke-width="3" stroke-linecap="round" fill="none"/>
  <path d="M151,362 Q160,370 169,362" stroke="rgba(80,30,8,.2)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
