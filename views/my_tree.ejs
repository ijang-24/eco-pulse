const BUILDERS = { 1:buildStage1, 2:buildStage2, 3:buildStage3, 4:buildStage4, 5:buildStage5 };
const MB_OFFSETS = { 1:30, 2:20, 3:40, 4:40, 5:38 }; // tree-container margin-bottom

/* =========================================================
   STAGE SWITCHER
========================================================= */
let currentStage = <%= tree.stage %>;

function initStage(s) {
  /* progress bar is dynamically filled by CSS class logic or inline below */
  document.getElementById('nfill').style.width = '<%= tree.progress %>%';

  /* stage tracker */
  for(let i=1;i<=5;i++) {
    document.getElementById('si'+i).classList.toggle('active', i <= s);
    document.getElementById('sd'+i).classList.toggle('active', i <= s);
    if(i<5) document.getElementById('sl'+i).classList.toggle('active', i < s);
  }

  /* tree svg */
  const tc = document.getElementById('treeContainer');
  tc.style.opacity = '0';
  tc.style.transform = 'scale(.9)';
  tc.style.transition = 'none';
  tc.style.marginBottom = MB_OFFSETS[s] + 'px';

  setTimeout(() => {
    tc.innerHTML = BUILDERS[s]();
    tc.style.transition = 'opacity .45s ease, transform .45s cubic-bezier(.34,1.56,.64,1)';
    tc.style.opacity = '1';
    tc.style.transform = 'scale(1)';
  }, 160);

  /* base shadow scale */
  const sw = [120, 160, 200, 240, 280][s-1];
  document.getElementById('baseShadow').style.width = sw + 'px';
}

/* =========================================================
   CLOUDS
========================================================= */
const cloudWrap = document.getElementById('clouds');
for(let i=0;i<6;i++) {
  const c = document.createElement('div');
  c.className = 'cloud';
  const w = 60 + Math.random()*100, h = w*.3;
  Object.assign(c.style, {
    width: w+'px', height: h+'px',
    top: (5+Math.random()*28)+'%',
    left: (Math.random()*100)+'%',
    animationDuration: (40+Math.random()*60)+'s',
    animationDelay: -(Math.random()*60)+'s',
    opacity: String(.6+Math.random()*.38)
  });
  c.innerHTML = `<div style="position:absolute;width:${w*.5}px;height:${w*.5}px;background:white;border-radius:50%;top:-40%;left:10%;"></div>
                 <div style="position:absolute;width:${w*.62}px;height:${w*.62}px;background:white;border-radius:50%;top:-52%;right:14%;"></div>`;
  cloudWrap.appendChild(c);
}

/* =========================================================
   PARTICLES
========================================================= */
const pWrap = document.getElementById('parallax-front');

function spawnParticle() {
  const p = document.createElement('div');
  p.className = 'particle';
  const isGold = currentStage >= 5;
  const color  = isGold ? '#fef08a' : '#a7f3d0';
  const shadow = isGold ? '#eab308' : '#34d399';
  const size   = 4 + Math.random()*6;
  Object.assign(p.style, {
    width: size+'px', height: size+'px',
    background: color,
    boxShadow: `0 0 ${size*2}px ${shadow}, 0 0 ${size*4}px ${shadow}`,
    left: (20+Math.random()*60)+'%',
    bottom: (10+Math.random()*40)+'%',
    animationDuration: (6+Math.random()*6)+'s'
  });
  pWrap.appendChild(p);
  setTimeout(()=>p.remove(), 12000);
}
for(let i=0;i<15;i++) setTimeout(spawnParticle, Math.random()*5000);
setInterval(spawnParticle, 800);

/* =========================================================
   PROGRESS BAR INIT
========================================================= */
setTimeout(()=>{ document.getElementById('nfill').style.width = '<%= tree.progress %>%'; }, 500);

/* =========================================================
   MOUSE PARALLAX
========================================================= */
const bg    = document.getElementById('parallax-bg');
const mid   = document.getElementById('parallax-mid');
const front = document.getElementById('parallax-front');
const ui    = document.getElementById('parallax-ui');

document.addEventListener('mousemove', e => {
  const dx = (e.clientX - window.innerWidth/2)  / (window.innerWidth/2);
  const dy = (e.clientY - window.innerHeight/2) / (window.innerHeight/2);
  bg.style.transform    = `translate(${dx*-10}px, ${dy*-5}px)`;
  mid.style.transform   = `translate(${dx*-25}px, ${dy*-10}px)`;
  front.style.transform = `translate(${dx*-45}px, ${dy*-20}px)`;
  ui.style.transform    = `translate(${dx*15}px, ${dy*10}px)`;
});
document.addEventListener('mouseleave', () => {
  [bg,mid,front,ui].forEach(el => el.style.transform = 'translate(0,0)');
});

/* =========================================================
   INIT
========================================================= */
initStage(currentStage);
</script>
</body>
</html>