<div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-bold">Green Rewards</h1>
    <div class="bg-green-100 px-6 py-2 rounded-full border border-green-200">
        <span class="text-green-800 font-bold">Your Balance: <%= user.total_points %> 🪙</span>
    </div>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% if (rewards && rewards.length > 0) { %>
        <% rewards.forEach(reward => { %>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
                <div class="h-48 bg-gray-200 flex items-center justify-center text-4xl">
                    <% if (reward.image_url) { %>
                        <img src="<%= reward.image_url %>" class="w-full h-full object-cover">
                    <% } else { %>
                        🎁
                    <% } %>
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-bold mb-2"><%= reward.title %></h3>
                    <p class="text-gray-600 mb-4 text-sm"><%= reward.description %></p>
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="text-green-600 font-bold"><%= reward.points_cost %> Points</span>
                            <p class="text-xs text-gray-400">Stock: <%= reward.stock %></p>
                        </div>
                        <form action="/rewards/redeem/<%= reward.id %>" method="POST" onsubmit="return confirm('Redeem this reward for <%= reward.points_cost %> points?')">
                            <button type="submit" class="<%= user.total_points >= reward.points_cost ? 'bg-green-600 hover:bg-green-700' : 'bg-gray-400 cursor-not-allowed' %> text-white px-4 py-2 rounded-lg font-semibold" <%= user.total_points < reward.points_cost ? 'disabled' : '' %>>
                                Redeem
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="col-span-full text-center py-20 text-gray-500 italic">
            No rewards available at the moment. Keep saving the planet!
        </div>
    <% } %>
</div>
