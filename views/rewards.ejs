<section class="space-y-12">
    <!-- Rewards Header -->
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-amber-500 via-amber-400 to-orange-300 p-8 text-white shadow-[0_20px_50px_rgba(251,191,36,0.15)] lg:p-12">
        <div class="absolute -right-10 top-10 h-40 w-40 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
            <div>
                <p class="inline-flex rounded-full bg-white/15 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-white ring-1 ring-white/30">Green Economy</p>
                <h1 class="mt-4 text-4xl font-extrabold tracking-tight lg:text-5xl">Tukar Poin <span class="text-amber-100">Eco-Pulse</span></h1>
                <p class="mt-2 text-amber-50/90 font-medium">Ubah kontribusi lingkungan Anda menjadi manfaat ekonomi nyata.</p>
            </div>
            <div class="flex items-center gap-4 rounded-[2rem] bg-white px-8 py-4 shadow-xl shadow-amber-900/10 ring-1 ring-amber-200">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-100 text-amber-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.94 6.94a.75.75 0 111.06 1.06L9.06 9H11a1 1 0 110 2H9.06l.94.94a.75.75 0 11-1.06 1.06L7.44 11.5a.75.75 0 010-1.06l1.5-1.5z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Poin Anda</p>
                    <p class="text-3xl font-black text-slate-950 tracking-tighter"><%= user.total_points %> <span class="text-sm font-bold text-amber-600">🪙</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Rewards Grid -->
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <% if (rewards && rewards.length > 0) { %>
            <% rewards.forEach(reward => { %>
                <div class="group relative flex flex-col rounded-[2.5rem] border border-slate-100 bg-white p-4 shadow-[0_15px_40px_rgba(0,0,0,0.04)] transition hover:-translate-y-1 hover:shadow-[0_25px_60px_rgba(251,191,36,0.12)]">
                    <div class="relative h-56 w-full overflow-hidden rounded-[2rem] bg-slate-50">
                        <% if (reward.image_url) { %>
                            <img src="<%= reward.image_url %>" class="h-full w-full object-cover transition group-hover:scale-110">
                        <% } else { %>
                            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-amber-50 to-orange-50 text-6xl opacity-80">
                                🎁
                            </div>
                        <% } %>
                        <div class="absolute right-4 top-4 rounded-full bg-white/90 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-amber-600 backdrop-blur-sm shadow-sm ring-1 ring-amber-100">
                            Stok: <%= reward.stock %>
                        </div>
                    </div>

                    <div class="flex flex-1 flex-col p-4">
                        <h3 class="text-2xl font-extrabold text-slate-900 tracking-tight"><%= reward.title %></h3>
                        <p class="mt-2 flex-1 text-sm leading-6 text-slate-500 line-clamp-2"><%= reward.description %></p>
                        
                        <div class="mt-8 flex items-center justify-between gap-4 border-t border-slate-50 pt-6">
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Harga Tukar</p>
                                <p class="text-2xl font-black text-amber-600"><%= reward.points_cost %> <span class="text-xs">PTS</span></p>
                            </div>
                            <form action="/rewards/redeem/<%= reward.id %>" method="POST" onsubmit="return confirm('Tukarkan <%= reward.points_cost %> poin untuk reward ini?')" class="shrink-0">
                                <button type="submit" 
                                    class="<%= user.total_points >= reward.points_cost ? 'bg-slate-900 text-white hover:bg-emerald-600' : 'bg-slate-100 text-slate-400 cursor-not-allowed' %> flex h-12 items-center gap-2 rounded-2xl px-6 font-bold transition shadow-lg shadow-slate-200"
                                    <%= user.total_points < reward.points_cost ? 'disabled' : '' %>>
                                    Redeem
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full flex flex-col items-center justify-center py-20 text-center">
                <div class="flex h-20 w-20 items-center justify-center rounded-[2.5rem] bg-slate-50 text-slate-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <h3 class="mt-6 text-xl font-extrabold text-slate-900">Belum ada Reward</h3>
                <p class="mt-2 max-w-sm text-sm leading-6 text-slate-500">Saat ini belum ada item yang bisa ditukar. Terus kumpulkan poin untuk penawaran menarik berikutnya!</p>
            </div>
        <% } %>
    </div>
</section>
