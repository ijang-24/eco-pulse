<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap');

  .eco-landing {
    font-family: 'Plus Jakarta Sans', 'Nunito', sans-serif;
    color: #0f172a;
    background:
      radial-gradient(circle at 10% 0%, rgba(16, 185, 129, 0.26), transparent 28%),
      radial-gradient(circle at 90% 0%, rgba(56, 189, 248, 0.18), transparent 24%),
      radial-gradient(circle at 50% 100%, rgba(251, 191, 36, 0.14), transparent 26%),
      linear-gradient(180deg, #f3fff8 0%, #e9fbef 34%, #e8f7ff 100%);
  }

  .eco-nav {
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    border: 1px solid rgba(255, 255, 255, 0.55);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid rgba(209, 250, 229, 0.78);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 22px 60px rgba(15, 23, 42, 0.08);
  }

  .hero-heading {
    font-family: 'Nunito', 'Plus Jakarta Sans', sans-serif;
    letter-spacing: -0.05em;
  }

  .hero-glow {
    position: absolute;
    inset: auto auto 0 0;
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.28), transparent 62%);
    filter: blur(12px);
    pointer-events: none;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .float-slow {
    animation: floatY 8s ease-in-out infinite;
  }

  .float-slower {
    animation: floatY 11s ease-in-out infinite;
  }

  .float-pulse {
    animation: pulseGlow 4s ease-in-out infinite;
  }

  .orbit {
    animation: orbit 16s linear infinite;
    transform-origin: center;
  }

  .drift {
    animation: drift 14s linear infinite;
  }

  .leaf {
    position: absolute;
    pointer-events: none;
    color: rgba(16, 185, 129, 0.35);
    filter: drop-shadow(0 6px 10px rgba(16, 185, 129, 0.12));
    animation: leafFall linear infinite;
  }

  .section-badge {
    letter-spacing: 0.28em;
  }

  .score-chip {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.20), rgba(34, 197, 94, 0.10));
    border: 1px solid rgba(16, 185, 129, 0.28);
  }

  @keyframes floatY {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-14px); }
  }

  @keyframes pulseGlow {
    0%, 100% { transform: scale(1); opacity: 0.9; }
    50% { transform: scale(1.06); opacity: 1; }
  }

  @keyframes orbit {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes drift {
    0% { transform: translate3d(0, 0, 0) rotate(0deg); }
    25% { transform: translate3d(10px, -18px, 0) rotate(6deg); }
    50% { transform: translate3d(-4px, -30px, 0) rotate(-6deg); }
    75% { transform: translate3d(-10px, -12px, 0) rotate(8deg); }
    100% { transform: translate3d(0, 0, 0) rotate(0deg); }
  }

  @keyframes leafFall {
    0% { transform: translate3d(0, -10vh, 0) rotate(0deg); opacity: 0; }
    8% { opacity: 1; }
    100% { transform: translate3d(0, 112vh, 0) rotate(360deg); opacity: 0; }
  }

  .icon-bubble {
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .tree-stage {
    position: relative;
  }

  .tree-stage::after {
    content: '';
    position: absolute;
    inset: auto 18% 11% 18%;
    height: 22%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.42), transparent 68%);
    filter: blur(10px);
    border-radius: 999px;
  }

  @media (prefers-reduced-motion: reduce) {
    .float-slow,
    .float-slower,
    .float-pulse,
    .orbit,
    .drift,
    .leaf {
      animation: none !important;
    }

    .fade-up {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

