<section class="space-y-8">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-emerald-600 via-teal-500 to-cyan-400 p-8 text-white shadow-[0_20px_50px_rgba(16,185,129,0.15)] lg:p-12">
        <div class="absolute -right-10 top-10 h-40 w-40 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative">
            <p class="inline-flex rounded-full bg-white/15 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-white ring-1 ring-white/30">Community Impact</p>
            <h1 class="mt-4 text-4xl font-extrabold tracking-tight lg:text-5xl">Neighborhood <span class="text-emerald-200">Leaderboard</span></h1>
            <p class="mt-2 text-emerald-50/90 font-medium max-w-2xl">Peringkat partisipasi lingkungan berdasarkan kontribusi pengelolaan sampah dari tiap wilayah RT/RW.</p>
        </div>

        <!-- Community Goal Section -->
        <div class="mt-10 rounded-[2rem] bg-white/10 p-6 backdrop-blur-md ring-1 ring-white/20">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h3 class="text-xl font-bold text-white">Target Komunitas Bulan Ini</h3>
                    <p class="text-sm text-emerald-50">Kumpulkan total 500kg sampah untuk membuka reward spesial RT!</p>
                </div>
                <div class="flex-1 max-w-md">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-bold uppercase tracking-wider text-emerald-100"><%= communityGoal.current.toFixed(1) %> / <%= communityGoal.target %> kg</span>
                        <span class="text-xs font-bold text-white"><%= Math.round((communityGoal.current / communityGoal.target) * 100) %>%</span>
                    </div>
                    <div class="h-3 w-full overflow-hidden rounded-full bg-white/20">
                        <div class="h-full bg-gradient-to-r from-lime-400 to-emerald-400 shadow-[0_0_20px_rgba(163,230,53,0.5)] transition-all duration-1000" 
                             style="width: <%= Math.min((communityGoal.current / communityGoal.target) * 100, 100) %>%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="rounded-[2.5rem] border border-emerald-100 bg-white/95 p-6 shadow-[0_20px_60px_rgba(16,185,129,0.08)] backdrop-blur-xl lg:p-8">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-100 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400">
                        <th class="px-6 py-4">Rank</th>
                        <th class="px-6 py-4">Neighborhood (RT/RW)</th>
                        <th class="px-6 py-4">Total Eco-Points</th>
                        <th class="px-6 py-4">Waste Collected</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% if (leaderboard && leaderboard.length > 0) { %>
                        <% leaderboard.forEach((entry, index) => { %>
                            <tr class="group transition hover:bg-emerald-50/50">
                                <td class="px-6 py-6">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-full font-black 
                                        <%= index === 0 ? 'bg-amber-100 text-amber-600' : 
                                           index === 1 ? 'bg-slate-100 text-slate-500' : 
                                           index === 2 ? 'bg-orange-100 text-orange-600' : 'bg-slate-50 text-slate-400' %>">
                                        <% if (index === 0) { %>🥇<% } else if (index === 1) { %>🥈<% } else if (index === 2) { %>🥉<% } else { %><%= index + 1 %><% } %>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <p class="text-base font-extrabold text-slate-900"><%= entry.rt_rw %></p>
                                    <p class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest">Active Community</p>
                                </td>
                                <td class="px-6 py-6">
                                    <div class="flex items-center gap-2">
                                        <span class="text-lg font-black text-slate-900"><%= entry.total_points.toLocaleString() %></span>
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">PTS</span>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-bold text-slate-600"><%= entry.total_weight.toFixed(1) %> kg</span>
                                        <div class="h-1.5 w-24 overflow-hidden rounded-full bg-slate-100">
                                            <div class="h-full bg-emerald-500" style="width: <%= Math.min((entry.total_weight / (leaderboard[0].total_weight || 1)) * 100, 100) %>%"></div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center">
                                    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-slate-50 text-slate-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                        </svg>
                                    </div>
                                    <p class="mt-4 text-sm font-bold text-slate-400 uppercase tracking-widest">Data belum tersedia</p>
                                    <p class="mt-1 text-xs text-slate-400">Belum ada aktivitas pengelolaan sampah yang terverifikasi.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</section>