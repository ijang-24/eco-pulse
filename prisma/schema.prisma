generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)
}

model users {
  id           Int           @id @default(autoincrement())
  username     String        @db.VarChar(50)
  email        String        @unique @db.VarChar(100)
  password     String        @db.VarChar(255)
  address_rt   String?       @db.VarChar(10)
  address_rw   String?       @db.VarChar(10)
  role         String        @default("citizen") @db.VarChar(20)
  total_points Int           @default(0)
  current_streak Int         @default(0)
  last_log_date DateTime?    @db.Timestamp(6)
  created_at   DateTime      @default(now()) @db.Timestamp(6)
  redemptions  redemptions[]
  waste_logs   waste_logs[]
}

model waste_logs {
  id            Int      @id @default(autoincrement())
  user_id       Int?
  waste_type    String   @db.VarChar(100)
  weight        Decimal  @db.Decimal(10, 2)
  photo_url     String?  @db.VarChar(255)
  status        String   @default("pending") @db.VarChar(20)
  points_earned Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  user          users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model point_configs {
  id            Int      @id @default(autoincrement())
  waste_type    String   @unique @db.VarChar(100)
  points_per_kg Int
  co2_factor    Decimal  @db.Decimal(10, 3)
  tree_factor   Decimal  @db.Decimal(10, 4)
  updated_at    DateTime @updatedAt
}

model rewards {
  id          Int           @id @default(autoincrement())
  title       String        @db.VarChar(100)
  description String?
  points_cost Int
  stock       Int           @default(0)
  image_url   String?       @db.VarChar(255)
  created_at  DateTime      @default(now())
  redemptions redemptions[]
}

model redemptions {
  id           Int      @id @default(autoincrement())
  user_id      Int
  reward_id    Int
  redeemed_at  DateTime @default(now())
  status       String   @default("pending") @db.VarChar(20)
  voucher_code String?  @unique @db.VarChar(50)
  reward       rewards  @relation(fields: [reward_id], references: [id])
  user         users    @relation(fields: [user_id], references: [id])
}
